[*.cs]

# CA1416: Validate platform compatibility
dotnet_diagnostic.CA1416.severity = none

# CA1062: Validate arguments of public methods
# Justification: Adding ArgumentNullException throws would change runtime behavior.
# These are internal APIs exposed as public for testability/framework requirements.
dotnet_diagnostic.CA1062.severity = none

# CA1031: Do not catch general exception types
# Justification: Broad catch blocks in file-loading and network code are intentional
# to gracefully handle corrupted files and transient failures without crashing.
dotnet_diagnostic.CA1031.severity = none

# CA1002: Do not expose generic lists
# Justification: Changing List<T> to Collection<T> on public APIs would be a breaking
# change affecting all consumers. Deferred to a future major version.
dotnet_diagnostic.CA1002.severity = none

# CA2227: Collection properties should be read only
# Justification: MVVM data-binding and JSON deserialization require settable collection
# properties. Making them read-only would break serialization and UI binding.
dotnet_diagnostic.CA2227.severity = none

# CA2234: Pass System.Uri objects instead of strings
# Justification: HttpClient string overloads are used with well-known API endpoints.
# Converting to Uri adds complexity without meaningful safety benefit here.
dotnet_diagnostic.CA2234.severity = none

# CA2000: Dispose objects before losing scope
# Justification: FormUrlEncodedContent lifetime is managed by HttpClient.SendAsync;
# disposing before the request completes would cause failures.
dotnet_diagnostic.CA2000.severity = none

# CA1848: Use the LoggerMessage delegates
# Justification: High-performance logging is unnecessary for this desktop application.
# Structured logging via ILogger extension methods is sufficient.
dotnet_diagnostic.CA1848.severity = none

# CA1305: Specify IFormatProvider
# Justification: StringBuilder.AppendLine with interpolated strings is used to build
# file content (JSON, YAML, PO, etc.) where InvariantCulture is implicit and adding
# IFormatProvider overloads reduces readability without changing behavior.
dotnet_diagnostic.CA1305.severity = none

# CA1304: Specify CultureInfo
# Justification: char.ToUpper is used for ASCII-only casing in translation post-processing.
dotnet_diagnostic.CA1304.severity = none

# CA1307: Specify StringComparison for clarity
# Justification: All flagged call sites (IndexOf, Contains, Replace) on char/string
# already use ordinal comparison by default in .NET. The rule requests explicit
# specification purely for clarity — no behavioral difference exists.
dotnet_diagnostic.CA1307.severity = none

# CA1310: Specify StringComparison for correctness
# Justification: All flagged StartsWith/EndsWith calls compare against ASCII-only
# format tokens (e.g., "msgid", "[", "=>") in file parsers where locale-sensitivity
# is irrelevant. Adding StringComparison.Ordinal everywhere would be noise.
dotnet_diagnostic.CA1310.severity = none

# CS9113: Primary constructor parameter is unread
# Justification: Several save-strategy classes accept IFileService via primary constructor
# for DI contract consistency, even though their implementations use File.WriteAllText directly.
# The parameter is kept so the DI container can provide it if needed in the future.
dotnet_diagnostic.CS9113.severity = none

# CA1515: Consider making public types internal
# Justification: Many public types in executable projects are required for XAML binding,
# DI registration, and cross-project access. Changing them all to internal is not feasible
# without breaking the architecture.
dotnet_diagnostic.CA1515.severity = none

# CS8632: Now resolved — <Nullable>enable</Nullable> is active in Toucan.csproj (task 5.3)

# CS8601, CS8602, CS8604: Nullable reference type warnings — now enforced (task 5.3)

# CA2007: Consider calling ConfigureAwait on the awaited task
# Justification: In WPF/Avalonia desktop applications, ConfigureAwait(false) in UI-bound
# code causes post-await execution to leave the UI thread, breaking data binding updates.
# Library code (Toucan.Core) already uses ConfigureAwait where appropriate.
dotnet_diagnostic.CA2007.severity = none

# CA1707: Identifiers should not contain underscores
# Justification: Test method names use underscores for readability (e.g., Method_Scenario_Expected).
# Primary constructor parameters with underscores are also flagged unnecessarily.
dotnet_diagnostic.CA1707.severity = none

# CA1822: Member does not access instance data and can be marked as static
# Justification: Many methods are instance-bound for interface compliance, MVVM command binding,
# or future state access. Converting to static would break polymorphism and binding patterns.
dotnet_diagnostic.CA1822.severity = none

# CA1852: Type can be sealed because it has no subtypes
# Justification: Sealing all internal types is overly aggressive for this pass.
# Types are left unsealed for extensibility and test mocking flexibility.
dotnet_diagnostic.CA1852.severity = none

# CA1849: Call async-returning methods when in an async method
# Justification: Some synchronous calls within async methods are intentional (e.g., File.Exists,
# Stream.Read in tight loops). Converting all to async adds unnecessary overhead.
dotnet_diagnostic.CA1849.severity = none

# CA1308: Normalize strings to uppercase
# Justification: ToLowerInvariant is used for case-insensitive file extension comparison
# and language code normalization where uppercase would be semantically confusing.
dotnet_diagnostic.CA1308.severity = none

# CA1812: Avoid uninstantiated internal classes
# Justification: Classes are instantiated via DI container or reflection-based factories
# which the analyzer cannot detect.
dotnet_diagnostic.CA1812.severity = none

# CA1309: Use ordinal string comparison
# Justification: Same rationale as CA1307/CA1310 — covered by those suppressions.
dotnet_diagnostic.CA1309.severity = none

# CA1001: Types that own disposable fields should be disposable
# Justification: HttpClient instances are intentionally static and long-lived in provider
# classes per Microsoft guidance. They should not be disposed per-instance.
dotnet_diagnostic.CA1001.severity = none

# CA1063: Implement IDisposable correctly
# Justification: Suppressed alongside CA1001 — same HttpClient pattern applies.
dotnet_diagnostic.CA1063.severity = none

# CA1826: Use property instead of Linq Enumerable method
# Justification: Minor optimization suggestion that reduces readability of LINQ chains.
dotnet_diagnostic.CA1826.severity = none

# CA1860: Avoid using 'Enumerable.Any()' extension method
# Justification: Any() is more readable than Count > 0 in many LINQ contexts.
dotnet_diagnostic.CA1860.severity = none

# CA1867: Use char overload
# Justification: Minor performance suggestion; string overloads are more readable for
# multi-character escape sequences.
dotnet_diagnostic.CA1867.severity = none

# CA1824: Mark assemblies with NeutralResourcesLanguageAttribute
# Justification: Not relevant for this application's resource strategy.
dotnet_diagnostic.CA1824.severity = none

# CA2211: Non-constant fields should not be visible
# Justification: Static mutable fields in specific patterns (e.g., service instances)
# are acceptable in this codebase.
dotnet_diagnostic.CA2211.severity = none

# CA5392: Use DefaultDllImportSearchPaths attribute for P/Invokes
# Justification: No P/Invoke code in this project requires custom DLL search paths.
dotnet_diagnostic.CA5392.severity = none

# CA1816: Call GC.SuppressFinalize correctly
# Justification: Suppressed alongside CA1063 — same pattern applies.
dotnet_diagnostic.CA1816.severity = none

# CA1859: Use concrete types when possible for improved performance
# Justification: Interface-typed variables are used for DI and testability. Using concrete
# types would defeat the purpose of abstraction.
dotnet_diagnostic.CA1859.severity = none

# CA1051: Do not declare visible instance fields
# Justification: Some model classes use public fields for simplicity in data-transfer scenarios.
dotnet_diagnostic.CA1051.severity = none

# CS0414: Field is assigned but its value is never used
# Justification: Some factory delegates are stored for future use or reserved for upcoming
# features. Removing them would lose the DI wiring intent.
dotnet_diagnostic.CS0414.severity = none

# CA1875: Use Regex.Count
# Justification: Regex.Count may not be available in all target framework versions used during
# development. The Matches().Count pattern is functionally equivalent.
dotnet_diagnostic.CA1875.severity = none

# xUnit1051: Use TestContext.Current.CancellationToken
# Justification: Test methods pass CancellationToken.None explicitly for deterministic behavior.
# Using TestContext.Current adds non-determinism to test execution.
dotnet_diagnostic.xUnit1051.severity = none

# CA1861: Avoid constant arrays as arguments
# Justification: In test code, inline array creation improves readability and each test
# should be self-contained. Performance is not a concern in test methods.
dotnet_diagnostic.CA1861.severity = none

# CA1854: Prefer TryGetValue over ContainsKey + indexer
# Justification: Minor performance suggestion; ContainsKey + indexer is acceptable in test
# code for readability. The double-lookup overhead is negligible.
dotnet_diagnostic.CA1854.severity = none

# AVLN5001: Avalonia property is obsolete
# Justification: TextBox.Watermark → PlaceholderText migration is a separate UI task.
dotnet_diagnostic.AVLN5001.severity = none

# AVLN3001: XAML resource won't be reachable via runtime loader
# Justification: MainWindow is resolved through DI, not via XAML runtime loader.
dotnet_diagnostic.AVLN3001.severity = none
csharp_indent_labels = one_less_than_current
csharp_using_directive_placement = outside_namespace:silent
csharp_prefer_simple_using_statement = true:suggestion
csharp_prefer_braces = true:silent
csharp_style_namespace_declarations = block_scoped:silent
csharp_style_prefer_method_group_conversion = true:silent
csharp_style_prefer_top_level_statements = true:silent
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = false:silent
csharp_style_throw_expression = true:suggestion
csharp_space_around_binary_operators = before_and_after

[*.{cs,vb}]
#### Naming styles ####

# Naming rules

dotnet_naming_rule.interface_should_be_begins_with_i.severity = suggestion
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.non_field_members_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.non_field_members_should_be_pascal_case.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascal_case.style = pascal_case

# Symbol specifications

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.interface.required_modifiers = 

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.types.required_modifiers = 

dotnet_naming_symbols.non_field_members.applicable_kinds = property, event, method
dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.non_field_members.required_modifiers = 

# Naming styles

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.required_suffix = 
dotnet_naming_style.begins_with_i.word_separator = 
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.pascal_case.required_prefix = 
dotnet_naming_style.pascal_case.required_suffix = 
dotnet_naming_style.pascal_case.word_separator = 
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.pascal_case.required_prefix = 
dotnet_naming_style.pascal_case.required_suffix = 
dotnet_naming_style.pascal_case.word_separator = 
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_style_operator_placement_when_wrapping = beginning_of_line
tab_width = 4
indent_size = 4
end_of_line = crlf
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion
dotnet_style_prefer_auto_properties = true:silent
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:silent
dotnet_style_prefer_conditional_expression_over_return = true:silent
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_simplified_interpolation = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion
