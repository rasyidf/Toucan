<ui:FluentWindow
    x:Class="Toucan.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="clr-namespace:Toucan.Services"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:Toucan.Views"
    Width="858"
    Height="650"
    MinWidth="800"
    MinHeight="600"
    Title="Toucan"
    d:DesignHeight="450"
    ui:Design.Background="white"
    ui:Design.Foreground="#0a0a0a"
    ExtendsContentIntoTitleBar="True"
    Loaded="Window_Loaded"
    Closing="Window_Closing"
    WindowBackdropType="Auto"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <!-- Keybindings applied from KeybindingService in code-behind -->
    <Window.Resources>
        <converters:LanguageNameConverter x:Key="LanguageConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="titleBar"
                           Height="auto"/>
            <RowDefinition x:Name="toolBarRow"
                           Height="auto"/>
            <RowDefinition x:Name="contentRow"
                           Height="*"/>
            <RowDefinition x:Name="footerRow"
                           Height="32"/>

        </Grid.RowDefinitions>
        <ui:TitleBar Title="Toucan">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/Images/logo.png" Width="18" Height="18"/>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <views:MainMenu/>
            </ui:TitleBar.Header>
        </ui:TitleBar>


        <views:ToolBarView Grid.Row="1"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center">
            <views:ToolBarView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility"
                            Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToolbarVisible, Source={x:Static services:PanelService.Instance}}"
                                     Value="False">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ShowStartScreen}"
                                     Value="True">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:ToolBarView.Style>
        </views:ToolBarView>

        <Grid x:Name="contentGrid"
              Grid.Row="2"
              Grid.RowSpan="1"
              Visibility="{Binding ShowStartScreen, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="sidebarColumn"
                                  Width="200"/>
                <ColumnDefinition x:Name="sidebarSplitterColumn"
                                  Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="inspectorSplitterColumn"
                                  Width="Auto"/>
                <ColumnDefinition x:Name="inspectorColumn"
                                  Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: tree only -->
            <Grid Visibility="{Binding SidePanelVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}">
                <views:ResourcesView x:Name="resourcesView"
                                     Visibility="{Binding ResourcesVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}"
                                     SelectionChanged="TreeNamespace_SelectedItemChanged"
                                     ListSelectionChanged="ResourcesView_ListSelectionChanged"/>
            </Grid>

            <!-- Left splitter -->
            <GridSplitter
                Grid.Column="1"
                Width="2"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                Visibility="{Binding SidePanelVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}"/>

            <!-- Center: translation editor -->
            <views:TranslationDetailsView
                x:Name="translationDetailsView"
                Grid.Column="2"
                FirstPageClick="FirstPage"
                LastPageClick="LastPage"
                NextPageClick="NextPage"
                PreviousPageClick="PreviousPage"
                ShowAllClick="ShowAll"
                UpdateLanguageValue="UpdateLanguageValue"/>

            <!-- Right splitter -->
            <GridSplitter
                Grid.Column="3"
                Width="2"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                Visibility="{Binding InspectorVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}"/>

            <!-- Right inspector pane -->
            <views:InspectorView
                x:Name="inspectorView"
                Grid.Column="4"
                Visibility="{Binding InspectorVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}"/>

        </Grid>

        <!--  Start screen overlay - shown when no project is loaded -->
        <views:StartScreen
            x:Name="startScreen"
            Grid.Row="1"
            Grid.RowSpan="2"
            Visibility="{Binding ShowStartScreen, Converter={StaticResource BoolToVis}}"/>

        <!--  Zen mode overlay - covers all chrome when active -->
        <views:ZenEditorView
            x:Name="zenEditorView"
            Grid.Row="0"
            Grid.RowSpan="4"
            Panel.ZIndex="100"
            Visibility="{Binding ZenMode, Converter={StaticResource BoolToVis}}"/>


        <views:StatusBarView x:Name="RootStatusBar"
                             Grid.Row="3"
                             Visibility="{Binding StatusBarVisible, Source={x:Static services:PanelService.Instance}, Converter={StaticResource BoolToVis}}"/>

    </Grid>
</ui:FluentWindow>
