<UserControl
    x:Class="Toucan.Views.Settings.ShortcutsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel>
        <TextBlock Text="Keyboard Shortcuts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
        <ui:InfoBar
            Title="Keyboard shortcuts reference"
            Message="Custom keybindings coming in a future update."
            Severity="Informational"
            IsOpen="True"
            IsClosable="False"
            Margin="0,0,0,12"/>

        <ItemsControl x:Name="KeybindingsListView" MaxHeight="380">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Action}" FontSize="13"/>
                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding Shortcut}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
