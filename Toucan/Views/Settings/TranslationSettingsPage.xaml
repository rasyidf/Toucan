<UserControl
    x:Class="Toucan.Views.Settings.TranslationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel>
        <TextBlock Text="Translation" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Settings</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="TextGrammarWand24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Formality" FontWeight="SemiBold"/>
                        <TextBlock Text="Tone for machine translations" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox Width="140" SelectedValue="{Binding Formality, Mode=TwoWay}">
                <ComboBoxItem>Default</ComboBoxItem>
                <ComboBoxItem>Formal</ComboBoxItem>
                <ComboBoxItem>Informal</ComboBoxItem>
            </ComboBox>
        </ui:CardControl>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Context</TextBlock>
        <TextBlock Text="Provide context to improve translation quality" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
        <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                 Text="{Binding Context, Mode=TwoWay}"/>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Providers</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CloudSync24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Translation providers" FontWeight="SemiBold"/>
                        <TextBlock Text="Configure API keys and provider settings" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button Content="Configure..." Command="{Binding OpenProviderSettingsCommand}"/>
        </ui:CardControl>
    </StackPanel>
</UserControl>
