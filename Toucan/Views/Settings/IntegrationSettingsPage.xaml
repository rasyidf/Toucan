<UserControl
    x:Class="Toucan.Views.Settings.IntegrationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel>
        <TextBlock Text="System Integration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">File Association</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Document24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text=".tproj file association" FontWeight="SemiBold"/>
                        <TextBlock Text="Register Toucan as the handler for .tproj project files" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,3" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="Medium"/>
                </Border>
                <ui:Button x:Name="InstallButton" Content="Install" Padding="12,5" Click="Install_Click"/>
                <ui:Button x:Name="UninstallButton" Content="Uninstall" Padding="12,5" Margin="4,0,0,0" 
                           Appearance="Secondary" Click="Uninstall_Click"/>
            </StackPanel>
        </ui:CardControl>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Startup</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Power24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Open last project on startup" FontWeight="SemiBold"/>
                        <TextBlock Text="Automatically reopen the last project when Toucan starts" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch IsChecked="{Binding OpenLastProjectOnStartup, Mode=TwoWay}"/>
        </ui:CardControl>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Shell Integration</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="FolderOpen24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Open with Toucan" FontWeight="SemiBold"/>
                        <TextBlock Text="Add 'Open with Toucan' to Explorer context menu for folders" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="ShellInstallButton" Content="Install" Padding="12,5" Click="ShellInstall_Click"/>
                <ui:Button x:Name="ShellUninstallButton" Content="Uninstall" Padding="12,5" Margin="4,0,0,0"
                           Appearance="Secondary" Click="ShellUninstall_Click"/>
            </StackPanel>
        </ui:CardControl>

        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Information</TextBlock>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="File extension" FontWeight="SemiBold"/>
                        <TextBlock Text=".tproj (Toucan Translation Project)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <TextBlock Text="application/json" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,4">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Folder24" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Settings location" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SettingsPathText" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button Content="Open" Padding="12,5" Click="OpenSettingsFolder_Click"/>
        </ui:CardControl>
    </StackPanel>
</UserControl>
