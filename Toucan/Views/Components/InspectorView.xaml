<UserControl
    x:Class="Toucan.Views.InspectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:c="clr-namespace:Toucan.Converters"
    xmlns:services="clr-namespace:Toucan.Services"
    xmlns:views="clr-namespace:Toucan.Views"
    xmlns:viewmodels="clr-namespace:Toucan.ViewModels"
    x:Name="InspectorPanel"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
    d:DesignHeight="500"
    d:DesignWidth="280"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Panel Header -->
        <Border
            Padding="8,5"
            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
            CornerRadius="6,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="Inspector" />

                <ui:Button
                    Grid.Column="1"
                    Margin="{StaticResource ToolbarButtonMargin}"
                    Padding="{StaticResource ToolbarButtonPadding}"
                    Appearance="Transparent"
                    Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleInspectorCommand}"
                    ToolTip="Hide Inspector (Ctrl+Shift+I)">
                    <ui:SymbolIcon FontSize="12" Symbol="Dismiss16" />
                </ui:Button>
            </Grid>
        </Border>

        <!-- Tabbed content -->
        <TabControl Grid.Row="1" BorderThickness="0" Padding="0"
                    x:Name="InspectorTabs">
            <!-- Stats Tab -->
            <TabItem Header="Stats" Padding="8,4">
                <views:LanguagesView />
            </TabItem>

            <!-- Suggestions Tab -->
            <TabItem Header="Suggestions" Padding="8,4">
                <Grid Margin="8">
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasSelectedKeyDetails, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ui:SymbolIcon FontSize="32" Symbol="Lightbulb24" Opacity="0.4" />
                        <TextBlock
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Opacity="0.6"
                            Text="Select a key to see suggestions" />
                    </StackPanel>

                    <!-- Content -->
                    <StackPanel Visibility="{Binding HasSelectedKeyDetails, Converter={StaticResource BoolToVis}}">
                        <TextBlock
                            FontSize="11"
                            Opacity="0.6"
                            TextTrimming="CharacterEllipsis"
                            Text="{Binding SelectedKeyNamespace, StringFormat='Suggestions for: {0}'}"
                            Margin="0,0,0,6" />

                        <ListBox
                            ItemsSource="{Binding Suggestions}"
                            Background="Transparent"
                            BorderThickness="0"
                            MaxHeight="300"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding}"
                                        TextWrapping="Wrap"
                                        FontSize="12"
                                        Margin="0,2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- No matches fallback -->
                        <TextBlock
                            FontSize="11"
                            Opacity="0.5"
                            Margin="0,8,0,0"
                            Text="No similar translations found">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Suggestions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Details Tab -->
            <TabItem Header="Details" Padding="8,4">
                <Grid Margin="8">
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasSelectedKeyDetails, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ui:SymbolIcon FontSize="32" Symbol="Info24" Opacity="0.4" />
                        <TextBlock
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Opacity="0.6"
                            Text="Select a key to see details" />
                    </StackPanel>

                    <!-- Content -->
                    <ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Visibility="{Binding HasSelectedKeyDetails, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <!-- Key ID -->
                            <TextBlock FontSize="11" Opacity="0.6" Text="Key ID" Margin="0,0,0,2" />
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"
                                Text="{Binding SelectedKeyNamespace}"
                                Margin="0,0,0,12" />

                            <!-- Comment -->
                            <TextBlock FontSize="11" Opacity="0.6" Text="Comment" Margin="0,0,0,2" />
                            <TextBlock
                                FontSize="12"
                                TextWrapping="Wrap"
                                Margin="0,0,0,12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SelectedKeyComment}" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedKeyComment}" Value="">
                                                <Setter Property="Text" Value="(none)" />
                                                <Setter Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Languages -->
                            <TextBlock FontSize="11" Opacity="0.6" Text="Languages" Margin="0,0,0,2" />
                            <ItemsControl
                                ItemsSource="{Binding SelectedKeyLanguages}"
                                Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Text="{Binding}" Margin="0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Audit -->
                            <TextBlock FontSize="11" Opacity="0.6" Text="Audit" Margin="0,0,0,2" />
                            <TextBlock
                                FontSize="12"
                                TextWrapping="Wrap"
                                Text="{Binding SelectedKeyAuditInfo}"
                                Opacity="0.8" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
