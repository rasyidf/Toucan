<UserControl
    x:Class="Toucan.Views.TranslationDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Toucan.Converters"
    xmlns:components="clr-namespace:Toucan.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Toucan.Locales"
    d:Background="White"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <c:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6,6,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Local filter for translation IDs -->
            <Border Padding="5,4" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                <ui:TextBox
                    x:Name="IdFilterBox"
                    Icon="Filter16"
                    PlaceholderText="{x:Static loc:Strings.Editor_FilterPlaceholder}"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    FontSize="12" />
            </Border>

            <!-- Normal list view (hidden in focused mode) -->
            <ListBox
                x:Name="languageGroupContainer"
                Grid.Row="1"
                ItemsSource="{Binding PagingController.PageData}"
                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                Visibility="{Binding FocusedEditorMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingPanel.ScrollUnit="Pixel"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                Background="Transparent"
                BorderThickness="0"
                Padding="5"
                SelectionMode="Single"
                HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="Transparent"
                                        BorderThickness="2,0,0,0"
                                        Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <local:TranslationItemView DataContext="{Binding}" UpdateLanguageValue="LanguageValue_KeyUp" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Focused Editor mode: single item with navigation -->
            <Grid Grid.Row="1"
                  Visibility="{Binding FocusedEditorMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Navigation bar -->
                <Border Padding="8,4" Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ui:Button Padding="6,4" Appearance="Transparent" Command="{Binding FocusedPreviousCommand}" ToolTip="Previous (K/↑)">
                                <ui:SymbolIcon Symbol="ChevronUp20"/>
                            </ui:Button>
                            <ui:Button Padding="6,4" Appearance="Transparent" Command="{Binding FocusedNextCommand}" ToolTip="Next (J/↓)">
                                <ui:SymbolIcon Symbol="ChevronDown20"/>
                            </ui:Button>
                            <TextBlock Margin="12,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="{Binding FocusedIndex, Mode=OneWay, StringFormat='{}{0}'}"/><Run Text=" / "/><Run Text="{Binding PagingController.Data.Count, Mode=OneWay, FallbackValue=0}"/>
                            </TextBlock>
                        </StackPanel>
                        <ui:Button HorizontalAlignment="Right" Padding="6,4" Appearance="Transparent"
                                   Command="{Binding ToggleFocusedEditorCommand}" ToolTip="Exit focused mode">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Dismiss16" Margin="0,0,4,0"/>
                                <TextBlock Text="Exit" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Single focused item -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
                    <ContentControl
                        HorizontalAlignment="Stretch"
                        Content="{Binding ZenCurrentItem, Mode=OneWay}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:TranslationItemView DataContext="{Binding}" UpdateLanguageValue="LanguageValue_KeyUp"/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </ScrollViewer>
            </Grid>

            <StatusBar
                x:Name="RootStatusBar"
                Grid.Row="2"
                MinHeight="0"
                Margin="0"
                Padding="4,2">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem>
                    <components:PaginationControl
                        FirstPageCommand="{Binding FirstPageCommand}"
                        GoToPageCommand="{Binding GoToPageCommand}"
                        HasNextPage="{Binding PagingController.HasNextPage}"
                        HasPreviousPage="{Binding PagingController.HasPreviousPage}"
                        IsPartial="{Binding PagingController.IsPartial}"
                        LastPageCommand="{Binding LastPageCommand}"
                        NextPageCommand="{Binding NextPageCommand}"
                        PageButtons="{Binding PageButtons}"
                        PageMessage="{Binding PageMessage}"
                        PreviousPageCommand="{Binding PreviousPageCommand}"
                        ShowAllCommand="{Binding ShowAllCommand}" />
                </StatusBarItem>
            </StatusBar>

        </Grid>
    </Border>
</UserControl>
