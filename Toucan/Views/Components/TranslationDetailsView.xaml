<UserControl
    x:Class="Toucan.Views.TranslationDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Toucan.Converters"
    xmlns:components="clr-namespace:Toucan.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Toucan.Locales"
    d:Background="White"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <c:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6,6,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Local filter for translation IDs -->
            <Border Padding="5,4" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                <ui:TextBox
                    x:Name="IdFilterBox"
                    Icon="Filter16"
                    PlaceholderText="{x:Static loc:Strings.Editor_FilterPlaceholder}"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    FontSize="12" />
            </Border>

            <!-- ponytail: ListBox with VirtualizingStackPanel replaces ItemsControl for UI virtualization.
                 Only visible items create their visual tree. Selection chrome suppressed via style. -->
            <ListBox
                x:Name="languageGroupContainer"
                Grid.Row="1"
                ItemsSource="{Binding PagingController.PageData}"
                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                VirtualizingPanel.ScrollUnit="Pixel"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                Background="Transparent"
                BorderThickness="0"
                Padding="5"
                SelectionMode="Single"
                HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="Transparent"
                                        BorderThickness="2,0,0,0"
                                        Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <local:TranslationItemView DataContext="{Binding}" UpdateLanguageValue="LanguageValue_KeyUp" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StatusBar
                x:Name="RootStatusBar"
                Grid.Row="2"
                MinHeight="0"
                Margin="0"
                Padding="4,2">
                <StatusBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </StatusBar.ItemsPanel>
                <StatusBarItem>
                    <components:PaginationControl
                        FirstPageCommand="{Binding FirstPageCommand}"
                        GoToPageCommand="{Binding GoToPageCommand}"
                        HasNextPage="{Binding PagingController.HasNextPage}"
                        HasPreviousPage="{Binding PagingController.HasPreviousPage}"
                        IsPartial="{Binding PagingController.IsPartial}"
                        LastPageCommand="{Binding LastPageCommand}"
                        NextPageCommand="{Binding NextPageCommand}"
                        PageButtons="{Binding PageButtons}"
                        PageMessage="{Binding PageMessage}"
                        PreviousPageCommand="{Binding PreviousPageCommand}"
                        ShowAllCommand="{Binding ShowAllCommand}" />
                </StatusBarItem>
            </StatusBar>

        </Grid>
    </Border>
</UserControl>
