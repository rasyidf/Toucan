<UserControl x:Class="Toucan.Views.Components.ActivityBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="ActivityBarRoot"
    Width="36">
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <ItemsControl ItemsSource="{Binding Panels, ElementName=ActivityBarRoot}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Margin="0,4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ItemBd" Width="36" Height="36" Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="2,0,0,0" BorderBrush="Transparent"
                            ToolTip="{Binding Title}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ActivateCommand, ElementName=ActivityBarRoot}"
                                          CommandParameter="{Binding Id}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
