<UserControl
    x:Class="Toucan.Views.ZenEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="clr-namespace:Toucan.Services"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:Toucan.Views"
    xmlns:vm="clr-namespace:Toucan.ViewModels"
    d:Background="#222"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top hint bar -->
        <Border
            Grid.Row="0"
            Padding="16,8"
            Background="{DynamicResource SubtleFillColorTertiaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: mode badge + nav hints -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Mode badge -->
                    <Border Padding="6,2" CornerRadius="3" Margin="0,0,12,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditorMode, Source={x:Static services:PanelService.Instance}}" Value="{x:Static vm:EditorMode.Review}">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EditorMode, Source={x:Static services:PanelService.Instance}}" Value="{x:Static vm:EditorMode.Audit}">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="ZEN · EDITOR" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EditorMode, Source={x:Static services:PanelService.Instance}}" Value="{x:Static vm:EditorMode.Review}">
                                            <Setter Property="Text" Value="ZEN · REVIEW" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EditorMode, Source={x:Static services:PanelService.Instance}}" Value="{x:Static vm:EditorMode.Audit}">
                                            <Setter Property="Text" Value="ZEN · AUDIT" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <TextBlock VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                               Text="J/↓ next · K/↑ prev · Esc exit" />
                </StackPanel>

                <!-- Center: position indicator -->
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.6">
                    <Run Text="{Binding FocusedIndex, Mode=OneWay, StringFormat='{}{0}'}" /><Run Text=" / " /><Run Text="{Binding PagingController.Data.Count, Mode=OneWay, FallbackValue=0}" />
                </TextBlock>

                <!-- Right: exit button -->
                <ui:Button Grid.Column="2"
                           Appearance="Transparent"
                           Padding="8,4"
                           Command="{Binding ToggleZenModeCommand}"
                           ToolTip="Exit Zen Mode (Esc)">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Dismiss16" Margin="0,0,4,0" />
                        <TextBlock Text="Exit" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Border>

        <!-- Center: focused translation item -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="32,32" HorizontalAlignment="Stretch">
                <Border
                    MinWidth="500"
                    MaxWidth="900"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24,20">
                    <ContentControl
                        x:Name="ZenContent"
                        HorizontalAlignment="Stretch"
                        Content="{Binding ZenCurrentItem, Mode=OneWay}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:TranslationItemView DataContext="{Binding}" />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Border>
            </Border>
        </ScrollViewer>

        <!-- Bottom: language filter indicator -->
        <Border Grid.Row="2" Padding="16,6"
                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                Visibility="{Binding HasFocusedLanguageFilter, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Filter16" FontSize="12" Opacity="0.5" Margin="0,0,6,0" />
                <TextBlock FontSize="11" Opacity="0.6"
                           Text="{Binding FocusedLanguagesDisplay, FallbackValue='All languages'}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
