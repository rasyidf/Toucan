<UserControl x:Class="Toucan.Views.Components.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Toucan.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="28" d:DesignWidth="500">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel.Resources>
            <Style TargetType="Button" x:Key="PagerBtn">
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
        </StackPanel.Resources>

        <Button Style="{StaticResource PagerBtn}" Command="{Binding FirstPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding HasPreviousPage, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="First">
            <ui:SymbolIcon Symbol="ChevronDoubleLeft20" FontSize="12"/>
        </Button>
        <Button Style="{StaticResource PagerBtn}" Command="{Binding PreviousPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding HasPreviousPage, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="Previous">
            <ui:SymbolIcon Symbol="ChevronLeft20" FontSize="12"/>
        </Button>

        <ItemsControl ItemsSource="{Binding PageButtons, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="2,0" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Button Width="24" Height="24" Padding="0" Margin="1,0" BorderThickness="0" Background="Transparent"
                                                    Command="{Binding GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Number}">
                                                <TextBlock Text="{Binding Number, FallbackValue=0}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Width" Value="24"/>
                                                        <Setter Property="Height" Value="24"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Margin" Value="1,0"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock Text="…" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Style="{StaticResource PagerBtn}" Command="{Binding NextPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding HasNextPage, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="Next">
            <ui:SymbolIcon Symbol="ChevronRight20" FontSize="12"/>
        </Button>
        <Button Style="{StaticResource PagerBtn}" Command="{Binding LastPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding HasNextPage, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="Last">
            <ui:SymbolIcon Symbol="ChevronDoubleRight20" FontSize="12"/>
        </Button>

        <TextBlock Text="{Binding PageMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Center" Margin="8,0" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Button Content="Show All" FontSize="11" Height="22" Padding="8,2" Margin="4,0" Background="Transparent" BorderThickness="0"
                Command="{Binding ShowAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding IsPartial, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </StackPanel>
</UserControl>
