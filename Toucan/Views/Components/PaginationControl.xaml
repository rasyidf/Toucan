<UserControl
    x:Class="Toucan.Views.Components.PaginationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan.Views.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:Background="White"
    d:DesignHeight="28"
    d:DesignWidth="500"
    mc:Ignorable="d">
    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
        <StackPanel.Resources>
            <Style x:Key="PagerBtn" TargetType="Button">
                <Setter Property="Width" Value="24" />
                <Setter Property="Height" Value="24" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="1,0" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </StackPanel.Resources>

        <Button
            Command="{Binding FirstPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEnabled="{Binding HasPreviousPage, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource PagerBtn}"
            ToolTip="First">
            <ui:SymbolIcon FontSize="12" Symbol="ChevronDoubleLeft20" />
        </Button>
        <Button
            Command="{Binding PreviousPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEnabled="{Binding HasPreviousPage, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource PagerBtn}"
            ToolTip="Previous">
            <ui:SymbolIcon FontSize="12" Symbol="ChevronLeft20" />
        </Button>

        <ItemsControl
            Margin="2,0"
            HorizontalAlignment="Center"
            ItemsSource="{Binding PageButtons, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Button
                                                Width="24"
                                                Height="24"
                                                Margin="1,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Number}">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding Number, FallbackValue=0}" />
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                                        <Setter Property="Width" Value="24" />
                                                        <Setter Property="Height" Value="24" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Margin" Value="1,0" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                <Setter Property="IsEnabled" Value="False" />
                                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Margin="4,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Text="…" />
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button
            Command="{Binding NextPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEnabled="{Binding HasNextPage, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource PagerBtn}"
            ToolTip="Next">
            <ui:SymbolIcon FontSize="12" Symbol="ChevronRight20" />
        </Button>
        <Button
            Command="{Binding LastPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsEnabled="{Binding HasNextPage, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource PagerBtn}"
            ToolTip="Last">
            <ui:SymbolIcon FontSize="12" Symbol="ChevronDoubleRight20" />
        </Button>

        <TextBlock
            Margin="8,0"
            VerticalAlignment="Center"
            FontSize="11"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{Binding PageMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <Button
            Height="22"
            Margin="4,0"
            Padding="8,2"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding ShowAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Content="Show All"
            FontSize="11"
            IsEnabled="{Binding IsPartial, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </StackPanel>
</UserControl>
