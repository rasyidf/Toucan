<UserControl
    x:Class="Toucan.Views.LanguagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:Toucan.Views.Components"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:Toucan.Locales"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="clr-namespace:Toucan.Services"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Toucan.ViewModels"
    x:Name="LanguagesPanel"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="320"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:IsExpandedToIconConverter x:Key="IsExpandedToIconConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  Panel Header  -->
        <Border
            Padding="8,5"
            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
            CornerRadius="6,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="{x:Static loc:Strings.Panel_Languages}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding SummaryInfo.ToggleExpandAllCommand}"
                        ToolTip="Expand/Collapse All">
                        <ui:SymbolIcon FontSize="12" Symbol="{Binding SummaryInfo.ExpandState, Converter={StaticResource IsExpandedToIconConverter}, FallbackValue=ChevronDown16}" />
                    </ui:Button>

                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding ManageLanguagesCommand}"
                        ToolTip="Manage Languages">
                        <ui:SymbolIcon FontSize="12" Symbol="Settings16" />
                    </ui:Button>

                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleInspectorCommand}"
                        ToolTip="Hide Inspector Panel">
                        <ui:SymbolIcon FontSize="12" Symbol="Dismiss16" />
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Language Items  -->
        <ui:DynamicScrollViewer
            Grid.Row="1"
            HorizontalContentAlignment="Stretch"
            UseLayoutRounding="True">
            <ItemsControl Margin="1" ItemsSource="{Binding SummaryInfo.Details}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <components:LanguageGroupCard />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:DynamicScrollViewer>
    </Grid>
</UserControl>
