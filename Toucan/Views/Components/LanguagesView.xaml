<UserControl
    x:Class="Toucan.Views.LanguagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Toucan.ViewModels"
    x:Name="LanguagesPanel"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="320"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:LanguageNameConverter x:Key="LanguageConverter" />
        <converters:IsExpandedToIconConverter x:Key="IsExpandedToIconConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Visibility="{Binding LanguagesVisible, Converter={StaticResource BoolToVis}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  Panel Header  -->
        <Border
            Padding="8,5"
            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
            CornerRadius="6,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="Languages" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding SummaryInfo.ToggleExpandAllCommand}"
                        ToolTip="Expand/Collapse All">
                        <ui:SymbolIcon FontSize="12" Symbol="{Binding SummaryInfo.ExpandState, Converter={StaticResource IsExpandedToIconConverter}, FallbackValue=ChevronDown16}" />
                    </ui:Button>

                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding ManageLanguagesCommand}"
                        ToolTip="Manage Languages">
                        <ui:SymbolIcon FontSize="12" Symbol="Settings16" />
                    </ui:Button>

                    <ui:Button
                        Margin="{StaticResource ToolbarButtonMargin}"
                        Padding="{StaticResource ToolbarButtonPadding}"
                        Appearance="Transparent"
                        Command="{Binding ToggleLanguagesVisibilityCommand}"
                        ToolTip="Hide Languages Panel">
                        <ui:SymbolIcon FontSize="12" Symbol="Dismiss16" />
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Language Items  -->
        <ui:DynamicScrollViewer
            Grid.Row="1"
            HorizontalContentAlignment="Stretch"
            UseLayoutRounding="True">
            <ItemsControl Margin="1" ItemsSource="{Binding SummaryInfo.Details}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardExpander
                            Margin="1,2"
                            Padding="1"
                            CornerRadius="4"
                            IsExpanded="{Binding IsExpanded}"
                            Tag="{Binding DataContext, ElementName=LanguagesPanel}">
                            <!--  Right-click context menu on the card  -->
                            <ui:CardExpander.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Pre-translate">
                                        <MenuItem
                                            Command="{Binding PlacementTarget.Tag.PreTranslateLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            Header="Entire Language" />
                                        <MenuItem
                                            Command="{Binding PlacementTarget.Tag.PreTranslateNamespaceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            Header="By Namespace..." />
                                        <MenuItem
                                            Command="{Binding PlacementTarget.Tag.PreTranslateKeyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            Header="By Key..." />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.ApproveAllForLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        Header="Approve All" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.GenerateStatisticsForLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        Header="Statistics" />
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.DeleteLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        Header="Delete Language" />
                                    <MenuItem Command="{Binding PlacementTarget.Tag.ManageLanguagesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="Manage Languages..." />
                                </ContextMenu>
                            </ui:CardExpander.ContextMenu>

                            <!--  Header: language name left, progress+stats right-aligned  -->
                            <ui:CardExpander.Header>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Language name  -->
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding Language, Converter={StaticResource LanguageConverter}}" />

                                    <!--  Spacer pushes right  -->

                                    <!--  Fixed-width progress bar aligned right  -->
                                    <ProgressBar
                                        Grid.Column="2"
                                        Height="3"
                                        VerticalAlignment="Center"
                                        Maximum="100"
                                        Value="{Binding Percentage, FallbackValue=0, Mode=OneWay}" />

                                    <!--  Percentage  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{Binding Percentage, StringFormat=\{0:F0\}%, FallbackValue=0%}" />

                                    <!--  Count  -->
                                    <TextBlock
                                        Grid.Column="4"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Opacity="0.5"
                                        Text="{Binding TranslatedStats}" />
                                </Grid>
                            </ui:CardExpander.Header>

                            <!--  Expanded: clickable status breakdown with hover, badges, context menus  -->
                            <StackPanel Margin="0">
                                <!--  Translated  -->
                                <Border
                                    Margin="0,1"
                                    Padding="1,0"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Cursor="Hand"
                                    Tag="{Binding DataContext, ElementName=LanguagesPanel}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding
                                            Command="{Binding DataContext.FilterByLanguageStatusCommand, ElementName=LanguagesPanel}"
                                            CommandParameter="{Binding Language, StringFormat=translated:{0}}"
                                            MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.FilterByLanguageStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext.Language, RelativeSource={RelativeSource AncestorType=ContextMenu}, StringFormat=translated:{0}}"
                                                Header="Show Translated" />
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.ApproveAllForLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Header="Approve All Translated" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="#4CAF50"
                                            Symbol="Checkmark16" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="Translated" />
                                        <ui:Badge Grid.Column="2" Appearance="Success">
                                            <TextBlock FontSize="10" Text="{Binding Translated}" />
                                        </ui:Badge>
                                    </Grid>
                                </Border>

                                <!--  Empty  -->
                                <Border
                                    Margin="0,1"
                                    Padding="1,0"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Cursor="Hand"
                                    Tag="{Binding DataContext, ElementName=LanguagesPanel}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding
                                            Command="{Binding DataContext.FilterByLanguageStatusCommand, ElementName=LanguagesPanel}"
                                            CommandParameter="{Binding Language, StringFormat=empty:{0}}"
                                            MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.FilterByLanguageStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext.Language, RelativeSource={RelativeSource AncestorType=ContextMenu}, StringFormat=empty:{0}}"
                                                Header="Show Empty" />
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.PreTranslateLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Header="Pre-translate Missing" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="#FF9800"
                                            Symbol="Warning16" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="Empty" />
                                        <ui:Badge Grid.Column="2" Appearance="Caution">
                                            <TextBlock FontSize="10" Text="{Binding Empty}" />
                                        </ui:Badge>
                                    </Grid>
                                </Border>

                                <!--  Needs Review  -->
                                <Border
                                    Margin="0,1"
                                    Padding="1,0"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Cursor="Hand"
                                    Tag="{Binding DataContext, ElementName=LanguagesPanel}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding
                                            Command="{Binding DataContext.FilterByLanguageStatusCommand, ElementName=LanguagesPanel}"
                                            CommandParameter="{Binding Language, StringFormat=needsreview:{0}}"
                                            MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.FilterByLanguageStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext.Language, RelativeSource={RelativeSource AncestorType=ContextMenu}, StringFormat=needsreview:{0}}"
                                                Header="Show Needs Review" />
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.ApproveAllForLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                Header="Approve All" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="#2196F3"
                                            Symbol="ChatWarning16" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="Needs Review" />
                                        <ui:Badge Grid.Column="2" Appearance="Info">
                                            <TextBlock FontSize="10" Text="{Binding NeedsReview}" />
                                        </ui:Badge>
                                    </Grid>
                                </Border>

                                <!--  Approved  -->
                                <Border
                                    Margin="0,1"
                                    Padding="1,0"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Cursor="Hand"
                                    Tag="{Binding DataContext, ElementName=LanguagesPanel}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding
                                            Command="{Binding DataContext.FilterByLanguageStatusCommand, ElementName=LanguagesPanel}"
                                            CommandParameter="{Binding Language, StringFormat=approved:{0}}"
                                            MouseAction="LeftClick" />
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding PlacementTarget.Tag.FilterByLanguageStatusCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                CommandParameter="{Binding PlacementTarget.DataContext.Language, RelativeSource={RelativeSource AncestorType=ContextMenu}, StringFormat=approved:{0}}"
                                                Header="Show Approved" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="#8BC34A"
                                            Symbol="ShieldCheckmark16" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="Approved" />
                                        <ui:Badge Grid.Column="2" Appearance="Success">
                                            <TextBlock FontSize="10" Text="{Binding Approved}" />
                                        </ui:Badge>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ui:CardExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:DynamicScrollViewer>
    </Grid>
</UserControl>
