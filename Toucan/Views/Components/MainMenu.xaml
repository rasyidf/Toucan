<UserControl
    x:Class="Toucan.Views.MainMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:Toucan.Locales"
    xmlns:services="clr-namespace:Toucan.Services"
    xmlns:converters="clr-namespace:Toucan.Converters"
    d:DesignHeight="39.817"
    d:DesignWidth="705.829"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:InvertBoolConverter x:Key="InvertBool" />
    </UserControl.Resources>

    <Menu HorizontalAlignment="Left" Background="{x:Null}">
        <!-- File: project-level operations only -->
        <ui:MenuItem AutomationProperties.AccessKey="F" Header="{x:Static loc:Strings.Menu_File}">
            <ui:MenuItem
                Width="250"
                Command="{Binding NewFolderCommand}"
                Header="_New project"
                Icon="{ui:SymbolIcon Document20}"
                InputGestureText="Ctrl+Shift+N" />
            <ui:MenuItem
                Command="{Binding OpenFolderCommand}"
                Header="_Open folder"
                Icon="{ui:SymbolIcon Folder20}"
                InputGestureText="Ctrl+O" />
            <ui:MenuItem
                Command="{Binding OpenProjectFileCommand}"
                Header="Open project file..."
                Icon="{ui:SymbolIcon DocumentText20}" />
            <ui:MenuItem
                Header="_Open recent"
                InputGestureText="Ctrl+R"
                ItemsSource="{Binding RecentProjects}">
                <ui:MenuItem.ItemContainerStyle>
                    <Style TargetType="{x:Type MenuItem}">
                        <Setter Property="Header" Value="{Binding Path}"/>
                        <Setter Property="Command" Value="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                        <Setter Property="CommandParameter" Value="{Binding Path}"/>
                    </Style>
                </ui:MenuItem.ItemContainerStyle>
            </ui:MenuItem>
            <Separator />
            <ui:MenuItem
                Command="{Binding SaveCommand}"
                Header="_Save project"
                Icon="{ui:SymbolIcon Save20}"
                InputGestureText="Ctrl+S"
                IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem
                Command="{Binding SaveToCommand}"
                Header="Save _As"
                Icon="{ui:SymbolIcon SaveArrowRight20}"
                InputGestureText="F12"
                IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <Separator />
            <ui:MenuItem Header="Import / Export">
                <ui:MenuItem
                    Command="{Binding ImportCommand}"
                    Header="Import..."
                    Icon="{ui:SymbolIcon ArrowImport20}" />
                <ui:MenuItem
                    Command="{Binding ExportCommand}"
                    Header="Export..."
                    Icon="{ui:SymbolIcon ArrowExportLtr20}" />
                <Separator />
                <ui:MenuItem
                    Command="{Binding ImportExcelCommand}"
                    Header="Import Excel..."
                    Icon="{ui:SymbolIcon TableSimple20}" />
                <ui:MenuItem
                    Command="{Binding ExportExcelCommand}"
                    Header="Export Excel..."
                    Icon="{ui:SymbolIcon TableSimple20}" />
            </ui:MenuItem>
            <Separator />
            <ui:MenuItem
                Command="{Binding RevealInExplorerCommand}"
                Header="Reveal in Explorer"
                Icon="{ui:SymbolIcon FolderOpen20}"
                IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem
                Command="{Binding ShowProjectPropertiesCommand}"
                Header="Project Properties"
                Icon="{ui:SymbolIcon DocumentSettings20}"
                IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <Separator />
            <ui:MenuItem
                Command="{Binding CloseProjectCommand}"
                Header="Close"
                InputGestureText="Ctrl+F4"
                IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem
                Command="{Binding ExitCommand}"
                Header="_Exit"
                InputGestureText="Alt+F4" />
        </ui:MenuItem>

        <!-- Edit: item manipulation, contextual to selection -->
        <ui:MenuItem Name="itemMenu" Header="{x:Static loc:Strings.Menu_Edit}"
                     IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}">
            <ui:MenuItem
                MinWidth="190"
                Command="{Binding UndoCommand}"
                Header="_Undo"
                Icon="{ui:SymbolIcon ArrowUndo20}"
                InputGestureText="Ctrl+Z" />
            <ui:MenuItem
                Command="{Binding RedoCommand}"
                Header="_Redo"
                Icon="{ui:SymbolIcon ArrowRedo20}"
                InputGestureText="Ctrl+Y" />
            <Separator />
            <ui:MenuItem
                Header="Cut"
                Icon="{ui:SymbolIcon Cut20}"
                Command="{Binding EditCutCommand}" />
            <ui:MenuItem
                Header="Copy"
                Icon="{ui:SymbolIcon Copy20}"
                Command="{Binding EditCopyCommand}" />
            <ui:MenuItem
                Header="Paste"
                Icon="{ui:SymbolIcon ClipboardPaste20}"
                Command="{Binding EditPasteCommand}" />
            <Separator />
            <ui:MenuItem
                Command="{Binding NewItemCommand}"
                Header="Add _ID"
                InputGestureText="Ctrl+I" />
            <ui:MenuItem
                Command="{Binding NewLanguageCommand}"
                Header="Add Language"
                InputGestureText="Ctrl+L" />
            <ui:MenuItem
                Command="{Binding RenameItemCommand}"
                Header="_Rename"
                InputGestureText="F2" />
            <ui:MenuItem
                Command="{Binding DeleteItemCommand}"
                Header="_Delete"
                InputGestureText="Del" />
            <ui:MenuItem
                Command="{Binding DuplicateItemCommand}"
                Header="D_uplicate"
                InputGestureText="Ctrl+D" />
            <Separator />
            <ui:MenuItem Header="Copy as template">
                <ui:MenuItem Header="Template 1" Command="{Binding CopyAsTemplate1Command}" InputGestureText="Ctrl+1"/>
                <ui:MenuItem Header="Template 2" Command="{Binding CopyAsTemplate2Command}" InputGestureText="Ctrl+2"/>
                <ui:MenuItem Header="Template 3" Command="{Binding CopyAsTemplate3Command}" InputGestureText="Ctrl+3"/>
            </ui:MenuItem>
            <ui:MenuItem Header="Convert case">
                <ui:MenuItem Header="_lowercase" Command="{Binding ConvertLowercaseCommand}" />
                <ui:MenuItem Header="_UPPERCASE" Command="{Binding ConvertUppercaseCommand}" />
                <ui:MenuItem Header="_Sentence case" Command="{Binding ConvertSentenceCaseCommand}" />
                <ui:MenuItem Header="_Title Case" Command="{Binding ConvertTitleCaseCommand}" />
            </ui:MenuItem>
            <ui:MenuItem Header="Remove whitespace">
                <ui:MenuItem Header="_Trim" Command="{Binding TrimWhitespaceCommand}" />
                <ui:MenuItem Header="Trim _line by line" Command="{Binding TrimLineByLineCommand}" />
                <ui:MenuItem Header="_Simplify" Command="{Binding SimplifyWhitespaceCommand}" />
            </ui:MenuItem>
        </ui:MenuItem>

        <!-- Tools: translation & analysis operations -->
        <ui:MenuItem Header="Tools"
                     IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}">
            <ui:MenuItem
                MinWidth="220"
                Header="_Pre-Translate..."
                Command="{Binding PreTranslateBulkCommand}"
                Icon="{ui:SymbolIcon Translate20}" />
            <ui:MenuItem Header="_Fill empty translations..." Command="{Binding FillEmptyTranslationsCommand}" />
            <ui:MenuItem Header="_Delete unused translations..." Command="{Binding DeleteUnusedTranslationsCommand}" />
            <Separator />
            <ui:MenuItem Header="Validate Placeholders" Command="{Binding ValidatePlaceholdersCommand}" Icon="{ui:SymbolIcon CheckmarkSquare20}" />
            <ui:MenuItem Header="Generate Plural Forms" Command="{Binding GeneratePluralFormsCommand}" Icon="{ui:SymbolIcon TextNumberFormat20}" />
            <ui:MenuItem Header="Generate Gender Forms" Command="{Binding GenerateGenderFormsCommand}" Icon="{ui:SymbolIcon People20}" />
            <Separator />
            <ui:MenuItem Header="Statistics" Command="{Binding GenerateStatisticsBulkCommand}" Icon="{ui:SymbolIcon ChartMultiple20}" />
            <ui:MenuItem Header="Source Code" Command="{Binding ToggleAdvancedOptionsCommand}" Icon="{ui:SymbolIcon Code20}" />
        </ui:MenuItem>

        <!-- Find: search & filter -->
        <ui:MenuItem Header="{x:Static loc:Strings.Menu_Find}"
                     IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}">
            <ui:MenuItem
                MinWidth="200"
                Header="Find"
                Icon="{ui:SymbolIcon Search20}"
                Command="{Binding FindPromptCommand}"
                InputGestureText="Ctrl+F" />
            <ui:MenuItem
                Header="Find Next"
                Command="{Binding FindNextCommand}"
                InputGestureText="F3" />
            <Separator />
            <ui:MenuItem
                Header="Set Filter"
                Icon="{ui:SymbolIcon Filter20}"
                Command="{Binding SetFilterCommand}" />
            <ui:MenuItem
                Header="Filter By ID"
                Command="{Binding FilterByIdCommand}" />
            <Separator />
            <ui:MenuItem
                Header="Show untranslated"
                Command="{Binding ShowUntranslatedCommand}" />
            <ui:MenuItem
                Header="Show translated"
                Command="{Binding ShowTranslatedCommand}" />
            <ui:MenuItem
                Header="Show approved"
                Command="{Binding ShowApprovedCommand}" />
            <Separator />
            <ui:MenuItem
                Header="Clear filter"
                Icon="{ui:SymbolIcon FilterDismiss20}"
                Command="{Binding ClearFilterCommand}"
                InputGestureText="Esc" />
        </ui:MenuItem>

        <!-- View: layout & panels -->
        <ui:MenuItem Header="{x:Static loc:Strings.Menu_Views}">
            <ui:MenuItem MinWidth="200" Header="Tree View" Icon="{ui:SymbolIcon TextBulletListTree20}" Command="{Binding SwitchToTreeViewCommand}"
                         IsCheckable="True" IsChecked="{Binding IsTreeView, Mode=OneWay}" />
            <ui:MenuItem Header="List View" Icon="{ui:SymbolIcon List20}" Command="{Binding SwitchToListViewCommand}"
                         IsCheckable="True" IsChecked="{Binding IsTreeView, Converter={StaticResource InvertBool}, Mode=OneWay}" />
            <Separator />
            <ui:MenuItem Header="Focused Editor" Command="{Binding ToggleFocusedEditorCommand}" InputGestureText="Ctrl+E"
                         IsCheckable="True" IsChecked="{Binding FocusedEditorMode, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem Header="Zen Mode" Command="{Binding ToggleZenModeCommand}" InputGestureText="Ctrl+Shift+Enter"
                         IsCheckable="True" IsChecked="{Binding ZenMode, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem Header="Fullscreen" Command="{Binding ToggleFullscreenCommand}" InputGestureText="F11"/>
            <ui:MenuItem Header="Infinite Scroll" Command="{Binding ToggleInfiniteScrollCommand}"
                         IsCheckable="True" IsChecked="{Binding InfiniteScroll, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <Separator />
            <ui:MenuItem Header="Sidebar" Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleSidebarCommand}" InputGestureText="Ctrl+B"
                         IsCheckable="True" IsChecked="{Binding SidePanelVisible, Source={x:Static services:PanelService.Instance}, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem Header="Inspector" Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleInspectorCommand}" InputGestureText="Ctrl+Shift+I"
                         IsCheckable="True" IsChecked="{Binding InspectorVisible, Source={x:Static services:PanelService.Instance}, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem Header="Toolbar" Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleToolbarCommand}"
                         IsCheckable="True" IsChecked="{Binding ToolbarVisible, Source={x:Static services:PanelService.Instance}, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <ui:MenuItem Header="Footer Bar" Command="{Binding Source={x:Static services:PanelService.Instance}, Path=ToggleStatusBarCommand}"
                         IsCheckable="True" IsChecked="{Binding StatusBarVisible, Source={x:Static services:PanelService.Instance}, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
            <Separator />
            <ui:MenuItem Header="Suggestions" Command="{Binding ToggleSuggestionsCommand}"/>
            <ui:MenuItem Header="Machine translations" Command="{Binding ToggleShowMachineTranslationsCommand}"
                         IsCheckable="True" IsChecked="{Binding ShowMachineTranslations, Mode=OneWay}"
                         IsEnabled="{Binding ShowStartScreen, Converter={StaticResource InvertBool}}" />
        </ui:MenuItem>

        <!-- Help -->
        <ui:MenuItem Header="{x:Static loc:Strings.Menu_Help}">
            <ui:MenuItem
                Width="150"
                Command="{Binding ShowPreferencesCommand}"
                Header="Preferences"
                Icon="{ui:SymbolIcon Settings20}" />
            <Separator />
            <ui:MenuItem
                Command="{Binding HelpHomepageCommand}"
                Header="Homepage" />
            <ui:MenuItem
                Command="{Binding HelpAboutCommand}"
                Header="About" />
        </ui:MenuItem>
    </Menu>

</UserControl>
