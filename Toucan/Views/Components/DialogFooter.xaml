<UserControl x:Class="Toucan.Views.Components.DialogFooter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
        <StackPanel Margin="16,10" FlowDirection="RightToLeft" Orientation="Horizontal">
            <ui:Button x:Name="CancelBtn" Margin="8,0,0,0" Content="Cancel"/>
            <ui:Button x:Name="OkBtn" Appearance="Primary" Content="OK"/>
        </StackPanel>
    </Border>
</UserControl>
