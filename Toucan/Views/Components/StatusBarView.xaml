<UserControl
    x:Class="Toucan.Views.StatusBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="clr-namespace:Toucan.ViewModels.StatusBarPanels"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:Toucan.Core.Models;assembly=Toucan.Core"
    Height="32"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="PanelButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- ═══ VCS Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:VcsPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="BranchFork24" FontSize="14" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding Content}" />
                    <Border Margin="4,0,0,0" CornerRadius="6" Padding="4,0"
                            Background="{DynamicResource SystemFillColorCautionBrush}"
                            Visibility="{Binding Badge, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Badge}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Button>
        </DataTemplate>

        <!-- ═══ Translation Stats Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:TranslationStatsPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                <Button.ToolTip>
                    <ToolTip>
                        <StackPanel MinWidth="220" MaxWidth="340">
                            <TextBlock FontWeight="SemiBold" Text="Translation Statistics" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding TotalKeys, StringFormat='Total keys: {0}'}" />
                            <TextBlock Text="{Binding TranslatedKeys, StringFormat='Translated: {0}'}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding Errors, StringFormat='Errors: {0}'}" Margin="0,2,0,0" Foreground="#E74C3C" />
                            <TextBlock Text="{Binding Warnings, StringFormat='Warnings: {0}'}" Margin="0,2,0,6" Foreground="#F39C12" />
                            <ItemsControl ItemsSource="{Binding LanguageStats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="55" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Language}" FontSize="11" />
                                            <ProgressBar Grid.Column="1" Height="4" Margin="4,0"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding Percentage, Mode=OneWay}" />
                                            <TextBlock Grid.Column="2" Text="{Binding TranslatedStats}" FontSize="10" Opacity="0.7" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Translate24" FontSize="14" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding Content}" />
                    <Border Margin="4,0,0,0" CornerRadius="6" Padding="4,0"
                            Background="#E74C3C"
                            Visibility="{Binding Errors, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Errors}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                    </Border>
                    <Border Margin="4,0,0,0" CornerRadius="6" Padding="4,0"
                            Background="#F39C12"
                            Visibility="{Binding Warnings, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Warnings}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Button>
        </DataTemplate>

        <!-- ═══ Mode Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:ModePanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <Border Padding="6,2" CornerRadius="3"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <TextBlock Text="{Binding Content}" FontSize="10" FontWeight="Medium" />
                </Border>
            </Button>
        </DataTemplate>

        <!-- ═══ Project Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:ProjectPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Home24" FontSize="14" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding Content}" />
                    <Border Margin="6,0,0,0" CornerRadius="6" Padding="5,1"
                            Background="{DynamicResource SystemFillColorCautionBrush}"
                            Visibility="{Binding Badge, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Badge}" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Button>
        </DataTemplate>

        <!-- ═══ Status Panel Template (center text) ═══ -->
        <DataTemplate DataType="{x:Type panels:StatusPanel}">
            <TextBlock VerticalAlignment="Center" Margin="8,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="{Binding Content}" TextTrimming="CharacterEllipsis"
                       Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
        </DataTemplate>

        <!-- ═══ Language Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:LanguagePanel}">
            <Button x:Name="LangButton" Style="{StaticResource PanelButton}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}"
                    Click="LanguagePanel_Click">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="LocalLanguage24" FontSize="14" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding Content}" />
                </StackPanel>
                <Button.ContextMenu>
                    <ContextMenu ItemsSource="{Binding AvailableLanguages}">
                        <ContextMenu.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding}"/>
                                <Setter Property="Command" Value="{Binding DataContext.ClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Setter Property="CommandParameter" Value="{Binding}"/>
                            </Style>
                        </ContextMenu.ItemContainerStyle>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </DataTemplate>

        <!-- ═══ Encoding Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:EncodingPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <TextBlock Text="{Binding Content}" />
            </Button>
        </DataTemplate>

        <!-- ═══ Line Endings Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:LineEndingsPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <TextBlock Text="{Binding Content}" />
            </Button>
        </DataTemplate>

        <!-- ═══ Notifications Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:NotificationsPanel}">
            <Button Style="{StaticResource PanelButton}" Command="{Binding ClickCommand}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    ToolTip="{Binding ToolTip}">
                <Border CornerRadius="8" Padding="5,1"
                        Background="{DynamicResource SystemAccentColorPrimaryBrush}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="12" Foreground="White" />
                        <TextBlock Margin="3,0,0,0" Text="{Binding Badge}" FontSize="10" Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Button>
        </DataTemplate>

        <!-- ═══ Loading Panel Template ═══ -->
        <DataTemplate DataType="{x:Type panels:LoadingPanel}">
            <ui:ProgressRing Width="14" Height="14" Margin="4,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
        </DataTemplate>
    </UserControl.Resources>

    <Border Padding="4,0" Background="{DynamicResource ControlFillColorDefaultBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Left panels -->
                <ColumnDefinition Width="*" />   <!-- Center panels (status text) -->
                <ColumnDefinition Width="Auto" /> <!-- Right panels -->
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT PANELS ═══ -->
            <ItemsControl Grid.Column="0" ItemsSource="{Binding Registry.LeftPanels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- ═══ CENTER PANELS ═══ -->
            <ItemsControl Grid.Column="1" ItemsSource="{Binding Registry.CenterPanels}"
                          HorizontalAlignment="Stretch" Margin="8,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- ═══ RIGHT PANELS ═══ -->
            <ItemsControl Grid.Column="2" ItemsSource="{Binding Registry.RightPanels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
