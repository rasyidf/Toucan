<UserControl
    x:Class="Toucan.Views.Components.TranslationRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root">

    <Border
        Margin="0,1"
        Padding="1,0"
        Background="Transparent"
        CornerRadius="3"
        Cursor="Hand"
        MouseLeftButtonUp="OnRowClick"
        Tag="{Binding ElementName=Root}">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.ContextMenu>
            <ContextMenu Opened="OnContextMenuOpened" />
        </Border.ContextMenu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:SymbolIcon
                VerticalAlignment="Center"
                FontSize="11"
                Foreground="{Binding IconColor, ElementName=Root}"
                Symbol="{Binding Icon, ElementName=Root}" />
            <TextBlock
                Grid.Column="1"
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                FontSize="11"
                Text="{Binding Label, ElementName=Root}" />
            <ui:Badge Grid.Column="2" Appearance="{Binding BadgeAppearance, ElementName=Root}">
                <TextBlock FontSize="10" Text="{Binding Count, ElementName=Root}" />
            </ui:Badge>
        </Grid>
    </Border>
</UserControl>
