<ui:FluentWindow
    x:Class="Toucan.OptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings"
    Width="750" Height="550"
    MinWidth="650" MinHeight="450"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="CanResize"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Settings" Grid.Row="0" ShowHelp="False" ShowMaximize="False" ShowMinimize="False"/>

        <!-- Main: Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation using WPF-UI ListView -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="8,12" CornerRadius="0">
                <ui:ListView x:Name="NavList" SelectedIndex="0" SelectionChanged="NavList_SelectionChanged">
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,12,0"/>
                            <TextBlock Text="General" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Edit24" Margin="0,0,12,0"/>
                            <TextBlock Text="Editor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Globe24" Margin="0,0,12,0"/>
                            <TextBlock Text="Languages" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Translate24" Margin="0,0,12,0"/>
                            <TextBlock Text="Translation" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Keyboard24" Margin="0,0,12,0"/>
                            <TextBlock Text="Keyboard Shortcuts" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Folder24" Margin="0,0,12,0"/>
                            <TextBlock Text="Project" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,12,0"/>
                            <TextBlock Text="About" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                </ui:ListView>
            </Border>

            <!-- Content Pages -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <Grid>
                    <!-- Page: General -->
                    <StackPanel x:Name="PageGeneral" Visibility="Visible">
                        <TextBlock Text="General" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Default language" FontWeight="SemiBold"/>
                                    <TextBlock Text="Language for new projects" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding DefaultLanguage, Mode=TwoWay}">
                                <ComboBoxItem>en-US</ComboBoxItem>
                                <ComboBoxItem>en</ComboBoxItem>
                                <ComboBoxItem>fr-FR</ComboBoxItem>
                                <ComboBoxItem>es-ES</ComboBoxItem>
                                <ComboBoxItem>id-ID</ComboBoxItem>
                                <ComboBoxItem>zh-CN</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Page size" FontWeight="SemiBold"/>
                                    <TextBlock Text="Items per page in translation view" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding PageSizeText, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Max items" FontWeight="SemiBold"/>
                                    <TextBlock Text="Maximum items to load" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding MaxItemsText, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Pagination limit" FontWeight="SemiBold"/>
                                    <TextBlock Text="Truncate results over this count" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding TruncateSizeText, Mode=TwoWay}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- Page: Editor -->
                    <StackPanel x:Name="PageEditor" Visibility="Collapsed">
                        <TextBlock Text="Editor" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <TextBlock Text="Plain text keys" FontWeight="SemiBold"/>
                            </ui:CardControl.Header>
                            <CheckBox IsChecked="{Binding PlainTextKeys, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <TextBlock Text="Copy Templates" FontWeight="SemiBold" Margin="0,12,0,8"/>
                        <TextBox Text="{Binding CopyTemplate1, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CopyTemplate2, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CopyTemplate3, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBlock Text="Use %1 as placeholder for the key namespace" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Page: Languages -->
                    <StackPanel x:Name="PageLanguages" Visibility="Collapsed">
                        <TextBlock Text="Languages" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                        <TextBlock Text="Suggested Languages" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="These languages appear when clicking 'Add suggested' in the New Project dialog." FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

                        <Border BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" CornerRadius="4" MinHeight="100" MaxHeight="200" Margin="0,0,0,8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="SuggestedLanguagesList" ItemsSource="{Binding SuggestedLanguages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"/>
                                                <ui:Button Grid.Column="1" Padding="4,2" Appearance="Transparent"
                                                           Command="{Binding DataContext.RemoveSuggestedLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Dismiss16" FontSize="10"/>
                                                </ui:Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <ui:TextBox x:Name="NewSuggestedLangBox" Width="200" PlaceholderText="e.g. de-DE" Margin="0,0,8,0"/>
                            <ui:Button Content="Add" Click="AddSuggestedLanguage_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Page: Translation -->
                    <StackPanel x:Name="PageTranslation" Visibility="Collapsed">
                        <TextBlock Text="Translation" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Formality" FontWeight="SemiBold"/>
                                    <TextBlock Text="Tone for machine translations" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding Formality, Mode=TwoWay}">
                                <ComboBoxItem>Default</ComboBoxItem>
                                <ComboBoxItem>Formal</ComboBoxItem>
                                <ComboBoxItem>Informal</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock Text="Context" FontWeight="SemiBold" Margin="0,12,0,4"/>
                        <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding Context, Mode=TwoWay}"/>

                        <ui:Button Content="Configure providers..." Margin="0,8,0,0"
                                   Command="{Binding OpenProviderSettingsCommand}"/>
                    </StackPanel>

                    <!-- Page: Keyboard Shortcuts -->
                    <StackPanel x:Name="PageShortcuts" Visibility="Collapsed">
                        <TextBlock Text="Keyboard Shortcuts" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8">All keyboard shortcuts. Customization coming soon.</TextBlock>
                        <ListView x:Name="KeybindingsListView" MaxHeight="350">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Category" Width="100" DisplayMemberBinding="{Binding Category}"/>
                                    <GridViewColumn Header="Action" Width="180" DisplayMemberBinding="{Binding Action}"/>
                                    <GridViewColumn Header="Shortcut" Width="140" DisplayMemberBinding="{Binding Shortcut}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <!-- Page: Project (separate page for project-specific settings) -->
                    <StackPanel x:Name="PageProject" Visibility="Collapsed">
                        <TextBlock Text="Project Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16">These settings are stored in the project's toucan.project manifest and apply only to this project.</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Primary language" FontWeight="SemiBold"/>
                                    <TextBlock Text="Source language for translations" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="160" Text="{Binding ProjectPrimaryLanguage, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Save empty translations" FontWeight="SemiBold"/>
                                    <TextBlock Text="Write keys with empty values to output files" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <CheckBox IsChecked="{Binding ProjectSaveEmptyTranslations, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Translation order" FontWeight="SemiBold"/>
                                    <TextBlock Text="Key sort order when saving" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="180" SelectedValue="{Binding ProjectTranslationOrder, Mode=TwoWay}">
                                <ComboBoxItem>Alphabetically sorted</ComboBoxItem>
                                <ComboBoxItem>Primary language</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock Text="Project Copy Templates" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <TextBlock Text="Override app-level copy templates for this project" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding ProjectCopyTemplate1, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ProjectCopyTemplate2, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ProjectCopyTemplate3, Mode=TwoWay}" Margin="0,0,0,4"/>

                        <CheckBox Content="Save changes to project manifest" IsChecked="{Binding ApplyChangesToProject, Mode=TwoWay}" Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Page: About -->
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                        <TextBlock Text="About" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Image Source="/Assets/Images/logo.png" Width="48" Height="48" Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Toucan" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Professional i18n editor" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Version 0.10.0" Margin="0,0,0,4"/>
                        <TextBlock Text="© 2025 rasyid.dev" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                <ui:Button Content="Save" Width="90" Appearance="Primary" Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
