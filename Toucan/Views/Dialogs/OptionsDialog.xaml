<ui:FluentWindow
    x:Class="Toucan.OptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings"
    Width="750" Height="550"
    MinWidth="650" MinHeight="450"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="CanResize"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Settings" Grid.Row="0" ShowHelp="False" ShowMaximize="False" ShowMinimize="False"/>

        <!-- Main: Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="4,8" CornerRadius="0">
                <ui:ListView x:Name="NavList" SelectedIndex="0" SelectionChanged="NavList_SelectionChanged">
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,12,0"/>
                            <TextBlock Text="General" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PaintBrush24" Margin="0,0,12,0"/>
                            <TextBlock Text="Appearance" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Edit24" Margin="0,0,12,0"/>
                            <TextBlock Text="Editor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Translate24" Margin="0,0,12,0"/>
                            <TextBlock Text="Translation" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Keyboard24" Margin="0,0,12,0"/>
                            <TextBlock Text="Keyboard Shortcuts" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Globe24" Margin="0,0,12,0"/>
                            <TextBlock Text="Languages" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                    <ui:ListViewItem>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,12,0"/>
                            <TextBlock Text="About" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:ListViewItem>
                </ui:ListView>
            </Border>

            <!-- Content Pages -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
                <Grid>
                    <!-- Page: General -->
                    <StackPanel x:Name="PageGeneral" Visibility="Visible">
                        <TextBlock Text="General" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Language</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="LocalLanguage24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="App language" FontWeight="SemiBold"/>
                                        <TextBlock Text="UI language (requires restart)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding AppLanguage, Mode=TwoWay}" SelectedValuePath="Content">
                                <ComboBoxItem>en-US</ComboBoxItem>
                                <ComboBoxItem>id-ID</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Pagination</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DocumentOnePage24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Page size" FontWeight="SemiBold"/>
                                        <TextBlock Text="Items per page in translation view" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding PageSizeText, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="NumberSymbol24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Max items" FontWeight="SemiBold"/>
                                        <TextBlock Text="Maximum items to load" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding MaxItemsText, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Cut24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Pagination limit" FontWeight="SemiBold"/>
                                        <TextBlock Text="Truncate results over this count" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <TextBox Width="80" Text="{Binding TruncateSizeText, Mode=TwoWay}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- Page: Appearance -->
                    <StackPanel x:Name="PageAppearance" Visibility="Collapsed">
                        <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Theme</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DarkTheme24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="App theme" FontWeight="SemiBold"/>
                                        <TextBlock Text="Select Light, Dark, or follow system setting" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding Theme, Mode=TwoWay}" SelectedValuePath="Content">
                                <ComboBoxItem>System</ComboBoxItem>
                                <ComboBoxItem>Light</ComboBoxItem>
                                <ComboBoxItem>Dark</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Window</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Window24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Backdrop type" FontWeight="SemiBold"/>
                                        <TextBlock Text="Window material effect" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding BackdropType, Mode=TwoWay}" SelectedValuePath="Content">
                                <ComboBoxItem>Mica</ComboBoxItem>
                                <ComboBoxItem>Acrylic</ComboBoxItem>
                                <ComboBoxItem>None</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- Page: Editor -->
                    <StackPanel x:Name="PageEditor" Visibility="Collapsed">
                        <TextBlock Text="Editor" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Behavior</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="TextT24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Plain text keys" FontWeight="SemiBold"/>
                                        <TextBlock Text="Display keys as plain text instead of formatted" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <CheckBox IsChecked="{Binding PlainTextKeys, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="LocalLanguage24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Default language" FontWeight="SemiBold"/>
                                        <TextBlock Text="Language for new projects" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding DefaultLanguage, Mode=TwoWay}" SelectedValuePath="Content">
                                <ComboBoxItem>en-US</ComboBoxItem>
                                <ComboBoxItem>en</ComboBoxItem>
                                <ComboBoxItem>fr-FR</ComboBoxItem>
                                <ComboBoxItem>es-ES</ComboBoxItem>
                                <ComboBoxItem>de-DE</ComboBoxItem>
                                <ComboBoxItem>id-ID</ComboBoxItem>
                                <ComboBoxItem>zh-CN</ComboBoxItem>
                                <ComboBoxItem>ja-JP</ComboBoxItem>
                                <ComboBoxItem>ko-KR</ComboBoxItem>
                                <ComboBoxItem>pt-BR</ComboBoxItem>
                                <ComboBoxItem>ar-SA</ComboBoxItem>
                                <ComboBoxItem>hi-IN</ComboBoxItem>
                                <ComboBoxItem>ru-RU</ComboBoxItem>
                                <ComboBoxItem>th-TH</ComboBoxItem>
                                <ComboBoxItem>vi-VN</ComboBoxItem>
                                <ComboBoxItem>tr-TR</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Copy Templates</TextBlock>
                        <TextBlock Text="Use %1 as placeholder for the key namespace" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBox Text="{Binding CopyTemplate1, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CopyTemplate2, Mode=TwoWay}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CopyTemplate3, Mode=TwoWay}" Margin="0,0,0,4"/>
                    </StackPanel>

                    <!-- Page: Translation -->
                    <StackPanel x:Name="PageTranslation" Visibility="Collapsed">
                        <TextBlock Text="Translation" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Settings</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="TextGrammarWand24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Formality" FontWeight="SemiBold"/>
                                        <TextBlock Text="Tone for machine translations" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ComboBox Width="140" SelectedValue="{Binding Formality, Mode=TwoWay}">
                                <ComboBoxItem>Default</ComboBoxItem>
                                <ComboBoxItem>Formal</ComboBoxItem>
                                <ComboBoxItem>Informal</ComboBoxItem>
                            </ComboBox>
                        </ui:CardControl>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Context</TextBlock>
                        <TextBlock Text="Provide context to improve translation quality" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding Context, Mode=TwoWay}"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Providers</TextBlock>

                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CloudSync24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Translation providers" FontWeight="SemiBold"/>
                                        <TextBlock Text="Configure API keys and provider settings" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:Button Content="Configure..." Command="{Binding OpenProviderSettingsCommand}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- Page: Keyboard Shortcuts -->
                    <StackPanel x:Name="PageShortcuts" Visibility="Collapsed">
                        <TextBlock Text="Keyboard Shortcuts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12">All keyboard shortcuts. Customization coming soon.</TextBlock>

                        <ItemsControl x:Name="KeybindingsListView" MaxHeight="380">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Action}" FontSize="13"/>
                                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="8,4">
                                                <TextBlock Text="{Binding Shortcut}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Page: Languages -->
                    <StackPanel x:Name="PageLanguages" Visibility="Collapsed">
                        <TextBlock Text="Languages" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8">Suggested Languages</TextBlock>
                        <TextBlock Text="These languages appear when clicking 'Add suggested' in the New Project dialog." FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>

                        <!-- Add language input (Fluent card style) -->
                        <ui:CardControl Margin="0,0,0,12">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Add language" FontWeight="SemiBold"/>
                                        <TextBlock Text="Type a language code and press Add" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:TextBox x:Name="NewSuggestedLangBox" Width="140" PlaceholderText="e.g. de-DE"/>
                                <ui:Button Content="Add" Margin="8,0,0,0" Appearance="Primary" Click="AddSuggestedLanguage_Click"/>
                            </StackPanel>
                        </ui:CardControl>

                        <!-- Language list (card-style items) -->
                        <ItemsControl x:Name="SuggestedLanguagesList" ItemsSource="{Binding SuggestedLanguages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="4" Margin="0,2" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="Globe16" Margin="0,0,10,0" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="13" VerticalAlignment="Center"/>
                                            <ui:Button Grid.Column="2" Padding="4,2" Appearance="Transparent"
                                                       ToolTip="Remove"
                                                       Command="{Binding DataContext.RemoveSuggestedLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Dismiss16" FontSize="12"/>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Page: About -->
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                        <TextBlock Text="About" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <!-- App info card -->
                        <ui:CardControl Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/Images/logo.png" Width="36" Height="36" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Toucan" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Version 0.14.0" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <ui:Button Content="Copy" Padding="12,6" Command="{Binding CopyVersionCommand}"/>
                        </ui:CardControl>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Heart24" Margin="0,0,12,0"/>
                                <TextBlock Text="Sponsor on GitHub" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <!-- Help and support -->
                        <TextBlock Text="Help and support" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,10"/>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True"
                                       Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/rasyidf/Toucan/wiki">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Book24" Margin="0,0,12,0"/>
                                <TextBlock Text="Documentation" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True"
                                       Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/rasyidf/Toucan/discussions">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ChatMultiple24" Margin="0,0,12,0"/>
                                <TextBlock Text="Questions &amp; discussions" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True"
                                       Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/rasyidf/Toucan/issues">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="PersonFeedback24" Margin="0,0,12,0"/>
                                <TextBlock Text="Feedback" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True"
                                       Command="{Binding OpenLogLocationCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Folder24" Margin="0,0,12,0"/>
                                <TextBlock Text="Open log location" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <!-- Open source -->
                        <TextBlock Text="Open source" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,10"/>

                        <ui:CardAction Margin="0,0,0,4" IsChevronVisible="True"
                                       Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/rasyidf/Toucan">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Code24" Margin="0,0,12,0"/>
                                <TextBlock Text="Source code on GitHub" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardAction>

                        <TextBlock Text="© 2025 rasyid.dev · MIT License" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                <ui:Button Content="Save" Width="90" Appearance="Primary" Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
