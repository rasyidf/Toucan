<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.ProviderSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Toucan.ViewModels"
    Title="Provider Settings"
    Width="777"
    Height="619"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!--  Title bar  -->
        <ui:TitleBar
            Title="Provider Settings"
            Height="44"
            Padding="8,6">
            <ui:TitleBar.Header>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Provider Settings" />
                        <TextBlock
                            FontSize="11"
                            Foreground="Gray"
                            Text="Manage translation providers, options and secrets" />
                    </StackPanel>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Configuration"/>

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Shield24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Scope" FontWeight="SemiBold"/>
                                <TextBlock Text="Override at project level" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <CheckBox
                    Margin="0,0,0,8"
                    Content="Project (override)"
                    IsChecked="{Binding ProjectScope}" />

                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8" Text="Project Folder"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBox Width="160" Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Width="32"
                        Margin="6,0,0,0"
                        Command="{Binding SelectProjectFolderCommand}"
                        Content="..." />
                </StackPanel>

                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Providers"/>

                <ListBox
                    Height="220"
                    ItemsSource="{Binding Providers}"
                    SelectedItem="{Binding Selected}" d:ItemsSource="{d:SampleData ItemCount=2}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="2"
                                Padding="6"
                                Background="Transparent"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="{Binding Provider}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="Gray"
                                        Text="{Binding Provider, FallbackValue='(no id)'}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel
                    Margin="0,6,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <Button
                        Width="80"
                        Margin="0,0,6,0"
                        Command="{Binding AddProviderCommand}"
                        Content="Add" />
                    <Button
                        Width="80"
                        Command="{Binding RemoveSelectedCommand}"
                        Content="Remove" />
                </StackPanel>
            </StackPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Selected Provider"/>

                    <ui:CardControl Margin="0,0,0,8">
                        <ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CloudSync24" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Provider ID" FontWeight="SemiBold"/>
                                    <TextBlock Text="Unique identifier for this provider" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ui:CardControl.Header>
                        <TextBox Width="200" Text="{Binding Selected.Provider, UpdateSourceTrigger=PropertyChanged}" />
                    </ui:CardControl>

                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8" Text="Options"/>

                    <ui:CardControl Margin="0,0,0,4">
                        <ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Options24" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="Provider options" FontWeight="SemiBold"/>
                                    <TextBlock Text="Configuration key-value pairs" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>

                    <ItemsControl ItemsSource="{Binding Selected.Options}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="{Binding Key}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text=":" />
                                    <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8" Text="Secrets"/>

                    <ui:CardControl Margin="0,0,0,4">
                        <ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Key24" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="API keys &amp; secrets" FontWeight="SemiBold"/>
                                    <TextBlock Text="Sensitive credentials (stored securely)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>

                    <ItemsControl ItemsSource="{Binding Selected.Secrets}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="{Binding Key}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text=":" />
                                    <PasswordBox Grid.Column="2" PasswordChar="●" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button Content="Save" Width="90" Appearance="Primary" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
