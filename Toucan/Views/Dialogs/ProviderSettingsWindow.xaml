<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.ProviderSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Toucan.ViewModels"
    xmlns:converters="clr-namespace:Toucan.Converters"
    Title="Provider Settings"
    Width="820"
    Height="640"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="SysBoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!--  Title bar  -->
        <ui:TitleBar
            Title="Provider Settings"
            Height="44"
            Padding="8,6">
            <ui:TitleBar.Header>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Provider Settings" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Configure translation provider credentials and options" />
                    </StackPanel>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: scope + provider list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scope toggle -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" Text="Scope"/>
                    <CheckBox
                        Content="Project override"
                        IsChecked="{Binding ProjectScope}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding ProjectScope, Converter={StaticResource BoolToVis}}">
                        <TextBox Width="150" Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Width="32"
                            Margin="6,0,0,0"
                            Command="{Binding SelectProjectFolderCommand}"
                            Content="..." />
                    </StackPanel>
                </StackPanel>

                <!-- Provider list header -->
                <TextBlock Grid.Row="1" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" Text="Providers"/>

                <!-- Provider list -->
                <ListBox
                    Grid.Row="2"
                    ItemsSource="{Binding Providers}"
                    SelectedItem="{Binding Selected}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Provider}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Add/Remove buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button
                        x:Name="AddProviderButton"
                        Content="Add"
                        Margin="0,0,6,0"
                        Click="AddProvider_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AddProviderMenu"
                                         ItemsSource="{Binding AvailableDefinitions}">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding DisplayName}"/>
                                        <Setter Property="Command" Value="{Binding DataContext.AddProviderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button
                        Content="Remove"
                        Command="{Binding RemoveSelectedCommand}" />
                </StackPanel>
            </Grid>

            <!-- RIGHT PANEL: selected provider details -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="16,0,0,0">
                <StackPanel DataContext="{Binding}">
                    <!-- Provider header -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Selected.Provider, FallbackValue='No provider selected'}" />
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedDefinition.Description, FallbackValue='Select a provider from the list'}" />
                    </StackPanel>

                    <!-- Options section -->
                    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4" Text="Options"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"
                               Text="Non-secret configuration (endpoints, models, regions)"/>

                    <ItemsControl ItemsSource="{Binding OptionItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:KeyValueItem}">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0"
                                                Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                IsReadOnly="{Binding IsSchemaField}"
                                                PlaceholderText="key" />
                                    <ui:TextBox Grid.Column="2"
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{Binding Hint}" />
                                    <Button Grid.Column="3"
                                            Width="28" Height="28"
                                            Margin="4,0,0,0"
                                            Padding="0"
                                            Command="{Binding DataContext.RemoveOptionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsSchemaField, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                            ToolTip="Remove">
                                        <TextBlock Text="✕" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Margin="0,6,0,0"
                            Command="{Binding AddOptionCommand}"
                            Content="+ Add option"
                            FontSize="12"
                            Padding="8,4" />

                    <!-- Secrets section -->
                    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,20,0,4" Text="Secrets"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"
                               Text="API keys and tokens (stored encrypted via DPAPI)"/>

                    <ItemsControl ItemsSource="{Binding SecretItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:KeyValueItem}">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Grid.Column="0"
                                                Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                IsReadOnly="{Binding IsSchemaField}"
                                                PlaceholderText="key" />
                                    <ui:TextBox Grid.Column="2"
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{Binding Hint}" />
                                    <Button Grid.Column="3"
                                            Width="28" Height="28"
                                            Margin="4,0,0,0"
                                            Padding="0"
                                            Command="{Binding DataContext.RemoveSecretCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsSchemaField, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                            ToolTip="Remove">
                                        <TextBlock Text="✕" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Margin="0,6,0,0"
                            Command="{Binding AddSecretCommand}"
                            Content="+ Add secret"
                            FontSize="12"
                            Padding="8,4" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button Content="Save" Width="90" Appearance="Primary" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
