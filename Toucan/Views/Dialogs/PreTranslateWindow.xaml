<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.PreTranslateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Toucan.ViewModels"
    Title="Pre-Translate"
    Width="545"
    Height="461"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <converters:StringEqualsConverter x:Key="StringEqualsConverter" />
    </Window.Resources>

    <!-- DataContext set in code-behind from injected VM -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Pre-Translate"
            Height="44"
            Padding="8,6">
            <ui:TitleBar.Header>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="⚡" />
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Pre-Translate" />
                        <TextBlock
                            FontSize="11"
                            Foreground="Gray"
                            Text="Quickly generate or preview translations for target languages" />
                    </StackPanel>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>


            <Border
                Grid.Row="1"
                Padding="8"
                Background="#20101010"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Provider selection  -->
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="Translation service:" />
                        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                            <RadioButton
                                Margin="6,0"
                                Content="Google"
                                IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Google}" />
                            <RadioButton
                                Margin="6,0"
                                Content="DeepL"
                                IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=DeepL}" />
                            <RadioButton
                                Margin="6,0"
                                Content="Microsoft"
                                IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Microsoft}" />
                            <RadioButton
                                Margin="6,0"
                                Content="OpenAI"
                                IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=OpenAI}" />
                            <Button
                                Width="30"
                                Height="24"
                                Margin="12,0,0,0"
                                Command="{Binding OpenProviderSettingsCommand}"
                                Content="⚙"
                                ToolTip="Provider settings" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Languages list  -->
                    <StackPanel Grid.Row="1" Margin="0,6,0,8">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="Languages to translate:" />
                        <ScrollViewer Height="100" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AvailableLanguages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!--  Options  -->
                    <StackPanel Grid.Row="2" Orientation="Vertical">
                        <StackPanel
                            Margin="0,4"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <CheckBox
                                Margin="0,0,18,0"
                                Content="Reset Approved flag"
                                IsChecked="{Binding ResetApproved}" />
                            <CheckBox
                                Margin="0,0,18,0"
                                Content="Translate selected items only"
                                IsChecked="{Binding TranslateSelectedOnly}" />
                            <CheckBox Content="Overwrite existing translations" IsChecked="{Binding OverwriteExisting}" />
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ProgressBar
                    Grid.Row="0"
                    Height="14"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" />

                <Border
                    Grid.Row="1"
                    Margin="0,6,0,6"
                    Padding="6"
                    Background="#10101010"
                    CornerRadius="4">
                    <ListView
                        HorizontalAlignment="Stretch"
                        AlternationCount="2"
                        ItemsSource="{Binding PreviewResults}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#10FFFFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn
                                    Width="160"
                                    DisplayMemberBinding="{Binding Namespace}"
                                    Header="Namespace" />
                                <GridViewColumn
                                    Width="80"
                                    DisplayMemberBinding="{Binding Language}"
                                    Header="Language" />
                                <GridViewColumn
                                    Width="200"
                                    DisplayMemberBinding="{Binding SourceText}"
                                    Header="Source" />
                                <GridViewColumn
                                    Width="200"
                                    DisplayMemberBinding="{Binding TranslatedValue}"
                                    Header="Proposed" />
                                <GridViewColumn Width="100" Header="Status">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Foreground="Gray"
                                                Text="{Binding ErrorMessage}"
                                                TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="Gray"
                    Text="Note: Your source language strings may be sent to the provider service." />
            </Grid>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <ui:Button x:Name="StartButton" Content="Preview" Width="90" Margin="0,0,8,0" Appearance="Primary" Click="StartButton_Click"/>
                <ui:Button Content="Apply Preview" Width="120" Click="ApplyButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
