<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.PreTranslateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Toucan.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Toucan.ViewModels"
    Title="Pre-Translate"
    Width="600"
    Height="620"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <converters:StringEqualsConverter x:Key="StringEqualsConverter" />
    </Window.Resources>

    <!-- DataContext set in code-behind from injected VM -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Pre-Translate"
            Height="44"
            Padding="8,6">
            <ui:TitleBar.Header>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="⚡" />
                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Pre-Translate" />
                        <TextBlock
                            FontSize="11"
                            Foreground="Gray"
                            Text="Quickly generate or preview translations for target languages" />
                    </StackPanel>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1" Padding="16,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Provider Selection -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Translation Service"/>

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CloudSync24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Provider" FontWeight="SemiBold"/>
                                <TextBlock Text="Select the translation service to use" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            Margin="6,0"
                            Content="Google"
                            IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Google}" />
                        <RadioButton
                            Margin="6,0"
                            Content="DeepL"
                            IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=DeepL}" />
                        <RadioButton
                            Margin="6,0"
                            Content="Microsoft"
                            IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Microsoft}" />
                        <RadioButton
                            Margin="6,0"
                            Content="OpenAI"
                            IsChecked="{Binding SelectedProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=OpenAI}" />
                        <Button
                            Width="30"
                            Height="24"
                            Margin="12,0,0,0"
                            Command="{Binding OpenProviderSettingsCommand}"
                            Content="⚙"
                            ToolTip="Provider settings" />
                    </StackPanel>
                </ui:CardControl>

                <!-- Target Languages -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8" Text="Target Languages"/>

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Translate24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Languages to translate" FontWeight="SemiBold"/>
                                <TextBlock Text="Select which languages to generate translations for" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" CornerRadius="4" Margin="0,0,0,8">
                    <ScrollViewer Height="100" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableLanguages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="8,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Options -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8" Text="Options"/>

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Options24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Translation options" FontWeight="SemiBold"/>
                                <TextBlock Text="Control how translations are applied" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <StackPanel Margin="8,4">
                    <CheckBox
                        Margin="0,0,18,0"
                        Content="Reset Approved flag"
                        IsChecked="{Binding ResetApproved}" />
                    <CheckBox
                        Margin="0,0,18,0"
                        Content="Translate selected items only"
                        IsChecked="{Binding TranslateSelectedOnly}" />
                    <CheckBox Content="Overwrite existing translations" IsChecked="{Binding OverwriteExisting}" />
                </StackPanel>

                <!-- Progress -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8" Text="Progress"/>

                <ProgressBar
                    Height="14"
                    Margin="0,0,0,6"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" />

                <Border
                    Padding="6"
                    Margin="0,0,0,6"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    MinHeight="120"
                    MaxHeight="160">
                    <ListView
                        HorizontalAlignment="Stretch"
                        AlternationCount="2"
                        ItemsSource="{Binding PreviewResults}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#10FFFFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn
                                    Width="160"
                                    DisplayMemberBinding="{Binding Namespace}"
                                    Header="Namespace" />
                                <GridViewColumn
                                    Width="80"
                                    DisplayMemberBinding="{Binding Language}"
                                    Header="Language" />
                                <GridViewColumn
                                    Width="200"
                                    DisplayMemberBinding="{Binding SourceText}"
                                    Header="Source" />
                                <GridViewColumn
                                    Width="200"
                                    DisplayMemberBinding="{Binding TranslatedValue}"
                                    Header="Proposed" />
                                <GridViewColumn Width="100" Header="Status">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Foreground="Gray"
                                                Text="{Binding ErrorMessage}"
                                                TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <TextBlock
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="Gray"
                    Text="Note: Your source language strings may be sent to the provider service." />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <ui:Button x:Name="StartButton" Content="Preview" Width="90" Margin="0,0,8,0" Appearance="Primary" Click="StartButton_Click"/>
                <ui:Button Content="Apply Preview" Width="120" Click="ApplyButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
