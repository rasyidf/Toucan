<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.ImportProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Import Existing Project"
    Width="600" Height="500"
    MinWidth="500" MinHeight="400"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Import Existing Project" Grid.Row="0" ShowHelp="False" ShowMaximize="False" ShowMinimize="False"/>

        <ScrollViewer Grid.Row="1" Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Import Project" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Select a folder containing translation files. Toucan will auto-detect the framework and languages."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <!-- Folder picker -->
                <TextBlock Text="Project Folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Folder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding BrowseFolderCommand}">
                        <ui:SymbolIcon Symbol="FolderOpen24"/>
                    </ui:Button>
                </Grid>

                <!-- Detected framework -->
                <TextBlock Text="Detected Framework" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,4" MinWidth="200"/>
                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Margin="0,0,0,16">
                    <Run Text="Auto-detected:"/>
                    <Run Text="{Binding DetectedProfile.DisplayName, Mode=OneWay, FallbackValue='(none)'}"/>
                </TextBlock>

                <!-- Discovered files -->
                <TextBlock Text="Discovered Files" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        CornerRadius="4" MaxHeight="150" Margin="0,0,0,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DiscoveredFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Language}" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RelativePath}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Detected languages -->
                <TextBlock Text="Languages" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding DetectedLanguages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="12,8,12,8" FlowDirection="RightToLeft" Orientation="Horizontal">
            <ui:Button Margin="0,0,8,0" Click="Cancel_Click">Cancel</ui:Button>
            <ui:Button Margin="0,0,8,0" Appearance="Primary" Click="Import_Click"
                       IsEnabled="{Binding IsValid}">Import</ui:Button>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
