<ui:FluentWindow
    x:Class="Toucan.Views.Dialogs.ImportProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Import Existing Project"
    Width="600" Height="500"
    MinWidth="500" MinHeight="400"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize">
    <Grid FocusManager.FocusedElement="{Binding ElementName=FolderPathBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Import Existing Project" Grid.Row="0" ShowHelp="False" ShowMaximize="False" ShowMinimize="False"/>

        <ScrollViewer Grid.Row="1" Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Import Project" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Select a folder containing translation files. Toucan will auto-detect the framework and languages."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <!-- Folder picker -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Project Folder"/>

                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Folder24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Folder path" FontWeight="SemiBold"/>
                                <TextBlock Text="Root folder containing your translation files" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button Command="{Binding BrowseFolderCommand}" ToolTip="Browse for folder" AutomationProperties.Name="Browse for folder">
                        <ui:SymbolIcon Symbol="FolderOpen24"/>
                    </ui:Button>
                </ui:CardControl>

                <TextBox x:Name="FolderPathBox" Text="{Binding Folder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Detected framework -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Detected Framework"/>

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="AppGeneric24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Framework profile" FontWeight="SemiBold"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="Auto-detected:"/>
                                    <Run Text="{Binding DetectedProfile.DisplayName, Mode=OneWay, FallbackValue='(none)'}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              MinWidth="200"/>
                </ui:CardControl>

                <!-- Discovered files -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8" Text="Discovered Files"/>

                <ui:CardControl Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentBulletList24" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="Translation files" FontWeight="SemiBold"/>
                                <TextBlock Text="Files detected in the selected folder" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        CornerRadius="4" MaxHeight="150" Margin="0,0,0,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DiscoveredFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Language}" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RelativePath}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Detected languages -->
                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Text="Languages"/>

                <ItemsControl ItemsSource="{Binding DetectedLanguages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button Content="Import" Width="90" Appearance="Primary" Click="Import_Click" IsEnabled="{Binding IsValid}"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
