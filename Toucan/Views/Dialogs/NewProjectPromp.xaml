<ui:FluentWindow
    x:Class="Toucan.NewProjectPrompt"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Width="640" Height="560"
    MinWidth="500" MinHeight="480"
    WindowStartupLocation="CenterOwner"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    ExtendsContentIntoTitleBar="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="New Project" ShowMaximize="False" ShowMinimize="False"/>

        <!-- Step 0: Framework + Title + Folder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStep0, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="20,8,20,8">
                <TextBlock Text="Step 1: Choose framework &amp; location" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="Select the framework used in your project:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>

                <!-- Framework tile grid -->
                <ItemsControl ItemsSource="{Binding Frameworks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton GroupName="Framework"
                                         IsChecked="{Binding IsSelected, Mode=TwoWay, RelativeSource={RelativeSource Self}}"
                                         Checked="FrameworkTile_Checked"
                                         Tag="{Binding}" Margin="4" Padding="0">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="TileBorder" Width="100" Height="80" CornerRadius="6"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                Padding="6" Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="9" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                <Setter TargetName="TileBorder" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,12,0,12"/>

                <!-- Project Name -->
                <TextBlock Text="Project Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="ProjectNameTextBox"
                            Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="My Translation Project"
                            Margin="0,0,0,12"/>

                <!-- Project Folder -->
                <TextBlock Text="Project Folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding ProjectFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Select folder..."/>
                    <ui:Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                               Command="{Binding BrowseFolderCommand}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Step 1: Languages -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="20,8,20,8">
                <TextBlock Text="Step 2: Configure languages" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="Add the languages you want to translate into:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>

                <!-- Languages -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Languages" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button Content="Add" Padding="8,4" Margin="0,0,4,0" Command="{Binding AddLanguageCommand}"/>
                        <ui:Button Content="Add suggested" Padding="8,4" Command="{Binding AddDefaultsCommand}"/>
                    </StackPanel>
                </Grid>

                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlElevationBorderBrush}" CornerRadius="4" MinHeight="120" MaxHeight="240">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Languages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"/>
                                        <ui:Button Grid.Column="1" Padding="4,2" Appearance="Transparent"
                                                   Command="{Binding DataContext.RemoveLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Dismiss16" FontSize="10"/>
                                        </ui:Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <CheckBox Content="Create manifest (toucan.project)" IsChecked="{Binding CreateManifest}" Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="20,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Content="← Back" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}"
                           Command="{Binding PreviousStepCommand}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button Content="Next →" Margin="0,0,8,0"
                               Visibility="{Binding IsStep0, Converter={StaticResource BoolToVis}}"
                               Command="{Binding NextStepCommand}" Appearance="Primary"/>
                    <ui:Button x:Name="CreateButton" Content="Create" Appearance="Primary"
                               Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}"
                               Width="90" Click="OKButton_Click" IsEnabled="{Binding IsValid}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>
</ui:FluentWindow>
