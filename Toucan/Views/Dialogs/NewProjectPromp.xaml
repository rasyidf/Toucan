<ui:FluentWindow
    x:Class="Toucan.NewProjectPrompt"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Width="640" Height="500"
    MinWidth="500" MinHeight="400"
    WindowStartupLocation="CenterOwner"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    ExtendsContentIntoTitleBar="True"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="New Project" ShowMaximize="False" ShowMinimize="False"/>

        <!-- Step 0: Framework + Title + Folder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStep0, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="20,8,20,8">
                <TextBlock Text="Step 1: Project setup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Project Name -->
                <TextBlock Text="Project Name" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="ProjectNameTextBox"
                            Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="My Translation Project"
                            Margin="0,0,0,10"/>

                <!-- Project Folder -->
                <TextBlock Text="Project Folder" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding ProjectFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Select folder..."/>
                    <ui:Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0"
                               Command="{Binding BrowseFolderCommand}"/>
                </Grid>

                <!-- Framework -->
                <TextBlock Text="Framework" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="Select the framework used in your project:" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>

                <!-- Framework tile grid -->
                <ItemsControl ItemsSource="{Binding Frameworks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton GroupName="Framework"
                                         IsChecked="{Binding IsSelected, Mode=TwoWay, RelativeSource={RelativeSource Self}}"
                                         Checked="FrameworkTile_Checked"
                                         Tag="{Binding}" Margin="2" Padding="0">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="TileBorder" Width="80" Height="60" CornerRadius="5"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                Padding="4" Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Icon}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="8" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                <Setter TargetName="TileBorder" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Step 1: Languages -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="20,8,20,8">
                <TextBlock Text="Step 2: Languages" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Add controls -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Target languages" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:Button Grid.Column="1" Content="Add" Padding="8,3" FontSize="11" Margin="0,0,4,0" Command="{Binding AddLanguageCommand}"/>
                    <ui:Button Grid.Column="2" Content="Suggested" Padding="8,3" FontSize="11" Appearance="Primary" Command="{Binding AddDefaultsCommand}"/>
                </Grid>

                <!-- Language list -->
                <ItemsControl ItemsSource="{Binding Languages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4" Margin="0,0,0,2" Padding="10,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Symbol="Globe16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" VerticalAlignment="Center"/>
                                    <ui:Button Grid.Column="2" Padding="3,2" Appearance="Transparent"
                                               Command="{Binding DataContext.RemoveLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}">
                                        <ui:SymbolIcon Symbol="Dismiss16" FontSize="10"/>
                                    </ui:Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <CheckBox Content="Create manifest (toucan.project)" IsChecked="{Binding CreateManifest}" Margin="0,12,0,0" FontSize="12"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Content="← Back" Width="90"
                           Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}"
                           Command="{Binding PreviousStepCommand}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button Content="Next →" Width="90" Margin="0,0,8,0" Appearance="Primary"
                               Visibility="{Binding IsStep0, Converter={StaticResource BoolToVis}}"
                               Command="{Binding NextStepCommand}"/>
                    <ui:Button x:Name="CreateButton" Content="Create" Width="90" Appearance="Primary"
                               Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}"
                               Click="OKButton_Click" IsEnabled="{Binding IsValid}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</ui:FluentWindow>
