<ui:FluentWindow
    x:Class="Toucan.LanguagePrompt"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Toucan"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:vm="clr-namespace:Toucan.ViewModels"
    Width="400"
    Height="180"
    MinWidth="320"
    MaxWidth="500"
    WindowStartupLocation="CenterOwner"
    WindowBackdropType="Tabbed"
    WindowCornerPreference="Round"  
    ExtendsContentIntoTitleBar="True" 
    mc:Ignorable="d">
    <!-- DataContext will be set from code-behind to pass existing languages for filtering -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="titleBar" Height="Auto" />
            <RowDefinition x:Name="contentRow" Height="*" />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>
        <ui:TitleBar
            x:Name="titleBarPrompt"
            Title="Add Language"
            VerticalAlignment="Center"
            ShowMaximize="false"
            ShowMinimize="false" />
        <Grid
            Grid.Row="1"
            Margin="16,2,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="messageLabel"
                Height="34"
                Margin="0,0,0,0"
                VerticalAlignment="Top"
                d:Text="Input" />

            <ui:AutoSuggestBox
                x:Name="ResponseLanguage"
                Grid.Row="1"
                ClearButtonEnabled="True"
                Margin="0,0,0,0"
                Icon="LocalLanguage20"
                ItemsSource="{Binding FilteredView, Mode=OneWay}"
                DisplayMemberPath="Language"
                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                PlaceholderText="Search or type a language code (eg. en, en-US)"
                VerticalAlignment="Top" />
        </Grid>
        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Width="90" Content="OK" Appearance="Primary" Click="OKButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
