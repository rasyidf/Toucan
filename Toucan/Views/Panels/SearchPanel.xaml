<UserControl x:Class="Toucan.Views.Panels.SearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search box: VM already debounces via OnSearchTextChanged -->
        <ui:TextBox Grid.Row="0"
                    PlaceholderText="Search translations..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,0,0,8"
                    Icon="{ui:SymbolIcon Search24}"/>

        <!-- Filter buttons -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <ui:Button Appearance="Transparent" Content="All" Padding="6,3" Margin="0,0,4,0" FontSize="11"
                       Command="{Binding ClearFilterCommand}"/>
            <ui:Button Appearance="Transparent" Content="Untranslated" Padding="6,3" Margin="0,0,4,0" FontSize="11"
                       Command="{Binding ShowUntranslatedCommand}"/>
            <ui:Button Appearance="Transparent" Content="Translated" Padding="6,3" Margin="0,0,4,0" FontSize="11"
                       Command="{Binding ShowTranslatedCommand}"/>
            <ui:Button Appearance="Transparent" Content="Approved" Padding="6,3" Margin="0,0,4,0" FontSize="11"
                       Command="{Binding ShowApprovedCommand}"/>
            <ui:Button Appearance="Transparent" Content="Used" Padding="6,3" Margin="0,0,4,0" FontSize="11"
                       Command="{Binding FilterUsedKeysCommand}"/>
            <ui:Button Appearance="Transparent" Content="Unused" Padding="6,3" FontSize="11"
                       Command="{Binding FilterUnusedKeysCommand}"/>
        </WrapPanel>

        <!-- Status / results count -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   FontSize="11"
                   Opacity="0.6"
                   Margin="0,0,0,4"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Placeholder when idle -->
        <TextBlock Grid.Row="3"
                   Text="Type to search across all keys and values"
                   FontSize="11"
                   Opacity="0.35"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SearchText}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
