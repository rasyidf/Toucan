<UserControl x:Class="Toucan.Views.Panels.MachineTranslationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: Provider badge + Pre-translate button -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource SystemAccentColorPrimaryBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppOptions.LastProvider}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
            </Border>
            <ui:Button Grid.Column="2" Content="Pre-translate" Icon="{ui:SymbolIcon Translate24}" Command="{Binding PreTranslateBulkCommand}" Appearance="Primary" Padding="12,6"/>
        </Grid>

        <!-- Status section -->
        <Border Grid.Row="1" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{DynamicResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="Provider ready" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </Grid>
        </Border>

        <!-- Provider quick-switch -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <StackPanel.Resources>
                <Style x:Key="ProviderChip" TargetType="ui:Button">
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </StackPanel.Resources>
            <ui:Button Content="Google" Style="{StaticResource ProviderChip}" Click="SwitchProvider_Click" Tag="Google"/>
            <ui:Button Content="DeepL" Style="{StaticResource ProviderChip}" Click="SwitchProvider_Click" Tag="DeepL"/>
            <ui:Button Content="Microsoft" Style="{StaticResource ProviderChip}" Click="SwitchProvider_Click" Tag="Microsoft"/>
            <ui:Button Content="OpenAI" Style="{StaticResource ProviderChip}" Click="SwitchProvider_Click" Tag="OpenAI"/>
        </StackPanel>

        <!-- Results / Empty state -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ui:SymbolIcon Symbol="Translate24" FontSize="32" Opacity="0.3" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Run pre-translate to see results here" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
