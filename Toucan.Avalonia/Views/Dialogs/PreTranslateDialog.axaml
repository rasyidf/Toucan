<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Toucan.Avalonia.Views.Dialogs.PreTranslateDialog"
        Title="Pre-Translate" Width="550" Height="450"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="12">
    <!-- Provider + options -->
    <StackPanel Spacing="6">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="Provider" FontWeight="SemiBold"/>
          <TextBox Text="{Binding SelectedProvider, Mode=TwoWay}" Margin="0,4,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
          <CheckBox Content="Overwrite existing" IsChecked="{Binding OverwriteExisting}"/>
          <CheckBox Content="Selected languages only" IsChecked="{Binding TranslateSelectedOnly}"/>
        </StackPanel>
      </Grid>
      <TextBlock Text="Languages" FontWeight="SemiBold" Margin="0,8,0,0"/>
      <ItemsControl ItemsSource="{Binding AvailableLanguages}">
        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="4,2"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- Results preview -->
    <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewResults}" IsReadOnly="True" Margin="0,8,0,0"/>

    <!-- Progress -->
    <StackPanel Grid.Row="2" Margin="0,8,0,0" IsVisible="{Binding IsRunning}">
      <ProgressBar Maximum="100" Value="{Binding ProgressPercent}" Height="6"/>
      <TextBlock Text="{Binding ProgressCompleted, StringFormat='{}{0} completed'}" FontSize="11" Opacity="0.7" Margin="0,2,0,0"/>
    </StackPanel>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button x:Name="CancelBtn" Content="Cancel" Width="80"/>
      <Button Content="Start" Command="{Binding StartCommand}" Width="80"/>
      <Button x:Name="CommitBtn" Content="Apply" Command="{Binding CommitCommand}" Width="80"/>
    </StackPanel>
  </Grid>
</Window>
