<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Toucan.Avalonia.Views.Dialogs.PromptDialog"
        Width="450" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <TextBlock x:Name="MessageLabel" TextWrapping="Wrap" Margin="0,0,0,8"/>
    <TextBox x:Name="ResponseTextBox" Grid.Row="1" Margin="0,4"/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
      <Button x:Name="CancelButton" Content="Cancel" Width="80"/>
      <Button x:Name="OkButton" Content="OK" Width="80"/>
    </StackPanel>
  </Grid>
</Window>
