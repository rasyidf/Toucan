<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Toucan.Avalonia.Views.Dialogs.ProviderSettingsDialog"
        Title="Provider Settings" Width="500" Height="400"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="App Settings" Command="{Binding LoadAppSettingsCommand}" Padding="6,2"/>
      <Button Content="Project Settings" Command="{Binding LoadProjectSettingsCommand}" Padding="6,2"/>
      <Button Content="Add" Command="{Binding AddProviderCommand}" Padding="6,2"/>
      <Button Content="Remove" Command="{Binding RemoveSelectedCommand}" Padding="6,2"/>
    </StackPanel>

    <ListBox Grid.Row="1" ItemsSource="{Binding Providers}" SelectedItem="{Binding Selected}" Margin="0,8,0,0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Provider}"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button x:Name="CloseBtn" Content="Close" Width="80"/>
      <Button Content="Save" Command="{Binding SaveCommand}" Width="80"/>
    </StackPanel>
  </Grid>
</Window>
