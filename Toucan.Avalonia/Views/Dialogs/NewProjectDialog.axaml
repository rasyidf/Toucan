<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Toucan.Avalonia.Views.Dialogs.NewProjectDialog"
        Title="New Project" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" CanResize="False"
        TransparencyLevelHint="Mica,AcrylicBlur,None" Background="Transparent"
        ExtendClientAreaToDecorationsHint="True" ExtendClientAreaTitleBarHeightHint="32">
  <Grid RowDefinitions="32,*" Margin="0">
    <!-- Title bar -->
    <TextBlock Text="Create New Project" Grid.Row="0" Margin="16,8,0,0"
               FontWeight="SemiBold" FontSize="12" Opacity="0.7" IsHitTestVisible="False"/>

    <Border Grid.Row="1" Padding="24,8,24,24">
      <StackPanel Spacing="16">
        <!-- Header -->
        <StackPanel Spacing="4">
          <TextBlock Text="🦜 New Translation Project" FontSize="20" FontWeight="Bold"/>
          <TextBlock Text="Set up your project in a few steps. You can change all settings later."
                     FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Step 1: Name + Folder -->
        <Border CornerRadius="6" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
          <StackPanel Spacing="10">
            <TextBlock Text="① Project Basics" FontWeight="SemiBold"/>
            <TextBox Text="{Binding ProjectName, Mode=TwoWay}" Watermark="Project name (e.g. My App)"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,0">
              <TextBox Text="{Binding ProjectFolder, Mode=TwoWay}" Watermark="Select a folder..."/>
              <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseFolderCommand}" Margin="6,0,0,0"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Step 2: Format -->
        <Border CornerRadius="6" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
          <StackPanel Spacing="10">
            <TextBlock Text="② Output Format" FontWeight="SemiBold"/>
            <TextBlock Text="How should translation files be stored?" FontSize="11" Opacity="0.6"/>
            <ComboBox ItemsSource="{Binding Frameworks}" SelectedItem="{Binding SelectedFramework}" MinWidth="200"/>
          </StackPanel>
        </Border>

        <!-- Step 3: Languages -->
        <Border CornerRadius="6" Padding="16" BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="③ Languages" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="Add suggested" Command="{Binding AddDefaultsCommand}" Padding="8,4"/>
            </Grid>
            <ScrollViewer MaxHeight="140">
              <ItemsControl ItemsSource="{Binding Languages}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                      <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="4,0"/>
                      <Button Grid.Column="1" Content="✕" Padding="4,2"
                              Command="{Binding $parent[Window].DataContext.RemoveLanguageCommand}"
                              CommandParameter="{Binding}"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <!-- Options -->
        <CheckBox Content="Generate project manifest (toucan.project)" IsChecked="{Binding CreateManifest}" Margin="4,0"/>

        <!-- Footer -->
        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
          <TextBlock Text="Translation files will be created in the selected folder."
                     FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
          <Button Grid.Column="1" x:Name="CancelButton" Content="Cancel" Width="80" Margin="0,0,8,0"/>
          <Button Grid.Column="2" x:Name="CreateButton" Content="Create" Width="90" IsEnabled="{Binding IsValid}"
                  Classes="accent"/>
        </Grid>
      </StackPanel>
    </Border>
  </Grid>
</Window>
