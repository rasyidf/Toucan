<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Toucan.Avalonia.Views.Dialogs.MessageWindow"
    Width="400"
    Height="160"
    WindowStartupLocation="CenterOwner"
    CanResize="False">

  <StackPanel Margin="12" Spacing="8">
    <TextBlock x:Name="TitleBlock" FontWeight="Bold" FontSize="16" />
    <ScrollViewer Height="60" VerticalScrollBarVisibility="Auto">
      <TextBlock x:Name="MessageBlock" TextWrapping="Wrap" />
    </ScrollViewer>
    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
      <Button x:Name="OkButton" Content="OK" Width="90"/>
    </StackPanel>
  </StackPanel>

</Window>
