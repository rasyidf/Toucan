<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Toucan.Avalonia.Views.Components.PaginationControl">
  <Border Padding="8,4">
    <Grid ColumnDefinitions="Auto,*,Auto">
      <!-- Navigation buttons -->
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
        <Button Command="{Binding FirstPageCommand}" IsEnabled="{Binding PagingController.HasPreviousPage}" Padding="6,3" ToolTip.Tip="First">
          <TextBlock Text="«" FontSize="14" FontWeight="Bold"/>
        </Button>
        <Button Command="{Binding PreviousPageCommand}" IsEnabled="{Binding PagingController.HasPreviousPage}" Padding="6,3" ToolTip.Tip="Previous">
          <TextBlock Text="‹" FontSize="14" FontWeight="Bold"/>
        </Button>

        <ItemsControl ItemsSource="{Binding PageButtons}" Margin="4,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="1"/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Panel>
                <Button Command="{Binding $parent[ItemsControl].DataContext.GoToPageCommand}"
                        CommandParameter="{Binding Number}"
                        IsVisible="{Binding !IsEllipsis}"
                        IsEnabled="{Binding !IsCurrent}"
                        Width="28" Height="28" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                  <TextBlock Text="{Binding Number}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Button>
                <TextBlock Text="⋯" IsVisible="{Binding IsEllipsis}" VerticalAlignment="Center" Margin="4,0" Opacity="0.5"/>
              </Panel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Command="{Binding NextPageCommand}" IsEnabled="{Binding PagingController.HasNextPage}" Padding="6,3" ToolTip.Tip="Next">
          <TextBlock Text="›" FontSize="14" FontWeight="Bold"/>
        </Button>
        <Button Command="{Binding LastPageCommand}" IsEnabled="{Binding PagingController.HasNextPage}" Padding="6,3" ToolTip.Tip="Last">
          <TextBlock Text="»" FontSize="14" FontWeight="Bold"/>
        </Button>
      </StackPanel>

      <!-- Page info -->
      <TextBlock Grid.Column="1" Text="{Binding PageMessage}" VerticalAlignment="Center" HorizontalAlignment="Center"
                 FontSize="11" Opacity="0.6"/>

      <!-- Show All -->
      <Button Grid.Column="2" Content="Show All" Command="{Binding ShowAllCommand}" 
              IsEnabled="{Binding PagingController.IsPartial}" Padding="8,4" FontSize="11" Opacity="0.7"/>
    </Grid>
  </Border>
</UserControl>
