<Application
    x:Class="Toucan.Avalonia.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sty="using:FluentAvalonia.Styling"
    RequestedThemeVariant="Light">

    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferSystemTheme="False" CustomAccentColor="#0097A7"/>
    </Application.Styles>
</Application>
